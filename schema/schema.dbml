// SBank Database Schema
// Generated: 2026-05-11
// DBMS: PostgreSQL 14+

// ============================================================
// 공통 코드 도메인
// ============================================================

Table 공통코드그룹 {
  그룹ID      varchar(50)  [pk]
  그룹명      varchar(100) [not null]
  설명        text
  사용여부    char(1)      [not null, default: 'Y']
  생성자ID    uuid
  수정자ID    uuid
  생성일시    timestamp    [not null, default: `CURRENT_TIMESTAMP`]
  수정일시    timestamp    [not null, default: `CURRENT_TIMESTAMP`]
}

Table 공통코드 {
  코드ID      bigserial    [pk]
  그룹ID      varchar(50)  [not null, ref: > 공통코드그룹.그룹ID]
  코드        varchar(50)  [not null]
  코드명      varchar(100) [not null]
  코드값      varchar(100)
  정렬순서    int          [not null, default: 0]
  사용여부    char(1)      [not null, default: 'Y']
  생성자ID    uuid
  수정자ID    uuid
  생성일시    timestamp    [not null, default: `CURRENT_TIMESTAMP`]
  수정일시    timestamp    [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    (그룹ID, 코드) [unique]
    그룹ID
  }
}


// ============================================================
// 고객 도메인 (Supertype / Subtype)
// ============================================================

Table 당사자 {
  당사자ID              uuid         [pk, default: `gen_random_uuid()`]
  당사자번호            varchar(30)  [not null, unique]
  당사자명              varchar(100) [not null]
  당사자개인법인구분    varchar(20)  [not null, note: 'INDIVIDUAL / CORPORATE']
  당사자상태            varchar(20)  [not null, default: 'ACTIVE', note: 'ACTIVE / SUSPENDED / DORMANT / WITHDRAWN']
  당사자상태사유        varchar(200)
  당사자상태변경일시    timestamptz

  생성자ID              uuid
  수정자ID              uuid
  생성일시              timestamptz  [not null, default: `now()`]
  수정일시              timestamptz  [not null, default: `now()`]
}

Table 개인고객 {
  개인고객ID               uuid         [pk, default: `gen_random_uuid()`]
  당사자ID                 uuid         [not null, unique, ref: - 당사자.당사자ID]
  개인고객전화번호         varchar(20)  [note: '휴대폰 번호 (예: 010-1234-5678)']
  개인고객이메일           varchar(200)
  개인고객CI               varchar(50)      [not null]
  성별                     char(1)          [not null]

  건별이체한도            decimal(15,2)
  일일이체한도            decimal(15,2)

  우편번호                varchar(5)
  주소                    varchar(200)
  상세주소                varchar(100)

  고용형태                varchar(20)  [note: 'EMPLOYED / SELF_EMPLOYED / CONTRACT / UNEMPLOYED / RETIRED']
  직장명                  varchar(100)
  직위                    varchar(50)
  업종코드                varchar(10)
  입사일                  date
  연소득                  decimal(15,2)

  개인고객상태            varchar(20)  [not null, default: 'ACTIVE', note: 'ACTIVE / SUSPENDED / DORMANT / WITHDRAWN']

  // 기업뱅킹 (법인 소속 시만 사용, 나머지는 NULL)
  법인ID                  uuid         [ref: > 법인고객.법인ID, note: '소속 법인 (기업뱅킹 사용자만)']
  담당부서                varchar(100)
  기업직급                varchar(100)
  기업뱅킹역할            varchar(30)  [note: 'VIEWER / TRANSFER_REQUESTER / APPROVER / ADMIN']
  기업뱅킹상태            varchar(20)  [note: 'ACTIVE / LOCKED / DISABLED. NULL=기업뱅킹 미사용']
  로그인실패횟수          int
  잠금일시                timestamptz
  최종로그인일시          timestamptz

  생성자ID                uuid
  수정자ID                uuid
  생성일시                timestamptz  [not null, default: `now()`]
  수정일시                timestamptz  [not null, default: `now()`]

  indexes {
    개인고객CI
  }
}

Table 법인고객 {
  법인ID                  uuid         [pk, default: `gen_random_uuid()`]
  당사자ID                uuid         [not null, unique, ref: - 당사자.당사자ID]

  // 기업 식별
  사업자등록번호          varchar(20)  [not null, note: '사업자등록번호']
  법인등록번호            varchar(20)  [note: '법인등록번호']

  // 기업 기본 정보
  기업유형                varchar(20)  [note: 'STOCK / LIMITED / COOPERATIVE / PUBLIC / OTHER']
  업종코드                varchar(10)  [note: 'KSIC 세세분류 5자리 (예: 47111=슈퍼마켓)']
  업태코드                varchar(10)  [note: 'KSIC 대분류 1자리 (예: G=도소매업)']
  설립일                  date
  결산월                  smallint     [note: '1–12']
  대표자명                varchar(100)
  대표자전화번호          varchar(20)
  대표자이메일            varchar(100)
  대표자국적              varchar(3)   [note: 'ISO 3166-1 alpha-3 (예: KOR, USA)']
  자본금                  decimal(15,2)

  // 사업장 주소
  사업장우편번호          varchar(5)
  사업장주소              varchar(200)
  사업장상세주소          varchar(100)

  // 등기주소 (법인등기부등본 기준 — 사업장 주소와 다를 경우 입력)
  등기우편번호            varchar(5)
  등기주소                varchar(200)
  등기상세주소            varchar(100)

  // 신용등급
  신용등급                varchar(10)  [note: 'AAA ~ D']
  신용평가사              varchar(50)  [note: 'NICE / KCB / KIS / SCI 등']
  신용평가일              date

  // 실소유자 확인 (AML)
  실소유자확인여부        boolean      [not null, default: false]
  실소유자확인일시        timestamptz

  생성자ID                uuid
  수정자ID                uuid
  생성일시                timestamptz  [not null, default: `now()`]
  수정일시                timestamptz  [not null, default: `now()`]
}

Table 당사자인증 {
  인증ID                  uuid         [pk, default: `gen_random_uuid()`]
  당사자ID                uuid         [not null, unique, ref: - 당사자.당사자ID]

  로그인ID                varchar(100) [not null, unique]
  비밀번호해시            varchar(255) [not null, note: 'bcrypt / argon2 해시']
  비밀번호솔트            varchar(255)

  비밀번호변경일시        timestamptz  [not null, default: `now()`]
  비밀번호만료일시        timestamptz

  상태                    varchar(20)  [not null, default: 'ACTIVE', note: 'ACTIVE / LOCKED / DISABLED']
  로그인실패횟수          int          [not null, default: 0]
  잠금일시                timestamptz

  최종로그인일시          timestamptz

  생성자ID                uuid
  수정자ID                uuid
  생성일시                timestamptz  [not null, default: `now()`]
  수정일시                timestamptz  [not null, default: `now()`]

  indexes {
    로그인ID
  }
}


// ============================================================
// 상품 도메인
// ============================================================

Table 상품 {
  상품ID                           uuid         [pk, default: `gen_random_uuid()`]
  상품명                           varchar(200) [not null]
  상품유형코드                     varchar(20)  [not null, note: 'common_code 참조 (그룹ID: PROD_TYPE) — DEPOSIT / LOAN']
  상태                             varchar(20)  [not null, default: 'ACTIVE', note: 'ACTIVE / INACTIVE / SUSPENDED']
  출시일                           varchar(8)  [not null]
  만료일                           date

  기간유형            varchar(20)   [not null, default: 'UNLIMITED', note: 'UNLIMITED=제한없음 / FIXED=고정 / FLEXIBLE=선택']
  계약기간_개월       integer       [note: 'FIXED=상품 고정 기간, FLEXIBLE=기본값 (개월)']

  판매대상            varchar(20)   [not null, default: 'ALL', note: 'ALL / INDIVIDUAL / CORPORATE']

  예금자보호여부      boolean      [not null, default: false, note: '예금보험공사 보호 여부']
  예금자보호한도      decimal(15,2) [note: '통상 50,000,000 (1인당 5천만원)']

  생성자ID    uuid        [not null]
  수정자ID    uuid        [not null]
  생성일시    timestamptz [not null, default: `now()`]
  수정일시    timestamptz [not null, default: `now()`]

  indexes {
    상품유형코드
    상태
  }
}

Table 상품약관 {
  약관ID       uuid        [pk, default: `gen_random_uuid()`]
  상품ID       uuid        [not null, ref: > 상품.상품ID]

  // TYPE_SPECIFIC(상품별 약관)
  약관유형     varchar(30) [not null, note: 'BASIC / TYPE_SPECIFIC']
  버전         varchar(20) [not null]
  시행일       varchar(8) [not null]
  종료일       varchar(8) [note: 'NULL=현재 유효']
  변경일시     timestamptz
  내용URL      text
  변경사유     text        [note: '버전 변경 사유 (예: 법령 개정, 약관 개선 등)']

  담당부서     varchar(100)
  담당직원ID   uuid        [ref: > 직원.직원ID]

  생성자ID     uuid
  수정자ID     uuid
  생성일시     timestamptz [not null, default: `now()`]
  수정일시     timestamptz [not null, default: `now()`]

  indexes {
    (상품ID, 약관유형, 버전) [unique]
  }
}

Table 상품금리 {
  상품금리ID   uuid         [pk, default: `gen_random_uuid()`]
  상품ID       uuid         [not null, ref: > 상품.상품ID]

  금리유형     varchar(20)  [not null, note: 'BASE / SPREAD']
  금리구조     varchar(20)  [not null, default: 'FIXED', note: 'FIXED=고정 / VARIABLE=변동 / CONFIRMED=확정']
  금리         decimal(7,4) [not null]
  적용시작일   varchar(8)  [not null]
  적용종료일   varchar(8)  [note: 'NULL=현재 적용 중']

  생성자ID     uuid         [not null]
  수정자ID     uuid
  생성일시     timestamptz  [not null, default: `now()`]
  수정일시     timestamptz  [not null, default: `now()`]

  indexes {
    상품ID
  }
}

Table 상품금리구간 {
  금리구간ID   uuid          [pk, default: `gen_random_uuid()`]
  상품ID       uuid          [not null, ref: > 상품.상품ID]

  구간유형     varchar(20)   [not null, note: 'AMOUNT / PERIOD']
  최솟값       decimal(15,2) [note: '구간 하한 (NULL=하한 없음)']
  최댓값       decimal(15,2) [note: '구간 상한 (NULL=상한 없음)']
  금리         decimal(7,4)  [not null]

  적용시작일   varchar(8)   [not null]
  적용종료일   varchar(8)   [note: 'NULL=현재 적용 중']

  생성자ID     uuid
  수정자ID     uuid
  생성일시     timestamptz   [not null, default: `now()`]
  수정일시     timestamptz   [not null, default: `now()`]

  indexes {
    상품ID
  }
}

Table 상품우대금리 {
  우대금리ID    uuid         [pk, default: `gen_random_uuid()`]
  상품ID        uuid         [not null, ref: > 상품.상품ID]

  우대조건명    varchar(100) [not null, note: '우대 조건명 (예: 급여이체 고객)']
  우대금리      decimal(7,4) [not null, note: '우대 금리 (예: 0.002 = +0.2%)']
  조건설명      text         [note: '조건 상세']

  적용시작일    varchar(8)  [not null]
  적용종료일    varchar(8)  [note: 'NULL=현재 적용 중']

  생성자ID      uuid
  수정자ID      uuid
  생성일시      timestamptz  [not null, default: `now()`]
  수정일시      timestamptz  [not null, default: `now()`]

  indexes {
    상품ID
  }
}

Table 상품수수료 {
  수수료ID      uuid         [pk, default: `gen_random_uuid()`]
  상품ID        uuid         [not null, ref: > 상품.상품ID]

  수수료유형    varchar(30)  [not null, note: 'TRANSFER=이체 / WITHDRAWAL=출금 / DEPOSIT=입금 / EARLY_REPAYMENT=중도상환 / OTHER=기타']
  채널          varchar(20)  [not null, default: 'ALL', note: 'ALL / APP / ATM / TELLER / INTERNET']

  구간하한      decimal(15,2) [note: 'NULL=하한 없음']
  구간상한      decimal(15,2) [note: 'NULL=상한 없음']

  고정수수료    decimal(15,2) [note: '원 단위 고정 수수료']
  비율수수료    decimal(7,4)  [note: '예: 0.001 = 0.1%']
  면제조건      text          [note: '예: 급여계좌, VIP 등']

  적용시작일    varchar(8)  [not null]
  적용종료일    varchar(8)  [note: 'NULL=현재 적용 중']

  생성자ID      uuid
  수정자ID      uuid
  생성일시      timestamptz  [not null, default: `now()`]
  수정일시      timestamptz  [not null, default: `now()`]

  indexes {
    상품ID
  }
}

Table 예금상세 {
  예금상세ID            uuid         [pk, default: `gen_random_uuid()`]
  상품ID                uuid         [not null, unique, ref: - 상품.상품ID]

  이자유형              varchar(10)  [not null, note: 'SIMPLE / COMPOUND']
  금리유형              varchar(10)  [not null, note: 'FIXED / VARIABLE']
  거래유형              varchar(20)  [not null, note: 'TIME_DEPOSIT / SAVINGS / DEMAND']

  최소금액              decimal(15,2)
  최대금액              decimal(15,2)
  최소기간월수          int
  최대기간월수          int
  중도해지위약금율      decimal(7,4)
  선납가능여부          boolean      [not null, default: false, note: '적금 전용']
  이연가능여부          boolean      [not null, default: false, note: '적금 전용']

  생성자ID              uuid
  수정자ID              uuid
  생성일시              timestamptz  [not null, default: `now()`]
  수정일시              timestamptz  [not null, default: `now()`]
}

Table 대출상세 {
  대출상세ID          uuid         [pk, default: `gen_random_uuid()`]
  상품ID              uuid         [not null, unique, ref: - 상품.상품ID]

  기준금리유형        varchar(20)  [not null, note: 'COFIX / CD91 / BASE_RATE / PRIME (실제 금리 값은 product_rate 참조)']
  이자유형            varchar(10)  [not null, note: 'SIMPLE=단리 / COMPOUND=복리']

  최대LTV비율         decimal(5,4)
  최대DTI비율         decimal(5,4)

  담보필요여부        boolean      [not null, default: false]
  담보유형            varchar(30)  [note: 'REAL_ESTATE / DEPOSIT / SECURITIES / NONE']
  질권설정가능여부    boolean      [not null, default: false]

  최소대출금액        decimal(15,2)
  최대대출금액        decimal(15,2)
  최대대출기간월수    int

  상환방식            varchar(25)  [not null, note: 'BULLET / EQUAL_PRINCIPAL / EQUAL_INSTALLMENT / FLEXIBLE']

  중도상환가능여부    boolean      [not null, default: false]
  중도상환수수료율    decimal(7,4) [note: '예: 0.014 = 1.4%']

  지연이자율          decimal(7,4) [note: '연체 시 적용. 예: 0.15 = 15%']

  생성자ID            uuid
  수정자ID            uuid
  생성일시            timestamptz  [not null, default: `now()`]
  수정일시            timestamptz  [not null, default: `now()`]
}

/*
BULLET	만기일시상환	매달 이자만 내다가 만기에 원금 전액 상환
EQUAL_PRINCIPAL	원금균등상환	매달 원금을 동일하게 나눠 상환, 이자는 줄어듦
EQUAL_INSTALLMENT	원리금균등상환	매달 납입액(원금+이자) 동일, 가장 일반적인 방식
FLEXIBLE	자유상환	납입 일정·금액을 자유롭게 선택
*/




// ============================================================
// 계약·계좌 도메인
// ============================================================

Table 계약 {
  계약ID                          uuid         [pk, default: `gen_random_uuid()`]
  당사자ID                        uuid         [not null, ref: > 당사자.당사자ID]
  상품ID                          uuid         [not null, ref: > 상품.상품ID]
  계약일                          varchar(8)  [not null]
  계약실행일자                    varchar(8)  [note: '대출 실행일·예금 개시일. NULL=즉시 실행']
  계약만기일                      varchar(8)  [note: '계약일 + 기간을 스냅샷으로 저장']
  계약종료일자                    varchar(8)  [note: '실제 종료일. 중도해지 시 만기일과 다름']
  계약기간_개월                   smallint     [note: '계약기간(개월). 수시입출금 등 기간 없는 상품은 NULL']
  계약금액                        decimal(15,2) [note: '대출=대출원금 / 적금=총납입목표액 / 정기예금=예치원금 / 보통예금=NULL']
  인지세                          decimal(15,2) [note: '대출 계약 시 납부. 대출금액 구간별 차등']
  계약상태                        varchar(25)  [not null, default: 'ACTIVE', note: 'ACTIVE / CLOSED / WITHDRAWN / ILLEGALLY_TERMINATED']
  최종적용금리                    decimal(7,4) [not null, note: '계약 시점 확정 금리 (기준+가산-우대). product_rate 변동과 무관하게 보존']

  지점ID                          uuid         [ref: > 지점.지점ID, note: 'NULL=비대면(앱·인터넷)']
  담당직원ID                      uuid         [ref: > 직원.직원ID]
  담당직원명                      varchar(100) [note: '스냅샷']
  계약서파일URL                   text

  생성자ID    uuid
  수정자ID    uuid
  생성일시    timestamptz [not null, default: `now()`]
  수정일시    timestamptz [not null, default: `now()`]

  indexes {
    당사자ID
    상품ID
    계약상태
    지점ID
  }
}

Table 계약약관동의 {
  계약ID      uuid        [not null, ref: > 계약.계약ID]
  약관ID      uuid        [not null, ref: > 상품약관.약관ID]

  약관동의일시    timestamptz [not null, default: `now()`]
  약관동의방식    varchar(20) [not null, note: 'APP / PAPER / KIOSK']
  계약방식       varchar(20) [not null, note: 'REMOTE=원격 / IN_PERSON=대면 / HYBRID=하이브리드']
  약관동의시IP주소      inet        [note: '약관 동의 시점 IP (비대면 채널)']

  생성자ID    uuid
  수정자ID    uuid
  생성일시    timestamptz [not null, default: `now()`]
  수정일시    timestamptz [not null, default: `now()`]

  indexes {
    (계약ID, 약관ID) [pk]
    계약ID
  }
}

Table 계약우대금리 {
  계약ID        uuid         [not null, ref: > 계약.계약ID]
  우대금리ID    uuid         [not null, ref: > 상품우대금리.우대금리ID]

  적용금리      decimal(7,4) [not null, note: '계약 당시 실제 적용된 우대금리 값 스냅샷']

  생성자ID      uuid
  수정자ID      uuid
  생성일시      timestamptz  [not null, default: `now()`]
  수정일시      timestamptz  [not null, default: `now()`]

  indexes {
    (계약ID, 우대금리ID) [pk]
    계약ID
  }
}

Table 계좌 {
  계좌ID                  uuid          [pk, default: `gen_random_uuid()`]
  계좌번호                varchar(30)   [not null, unique]
  계좌비밀번호hash        varchar(50)   [not null]
  당사자ID                uuid          [not null, ref: > 당사자.당사자ID]
  계약ID                  uuid          [ref: > 계약.계약ID]
  계좌유형                varchar(20)   [not null, note: 'DEPOSIT=예금 / LOAN=대출 / OVERDRAFT=마이너스통장']
  계좌상태                varchar(20)   [not null, default: 'ACTIVE', note: 'ACTIVE / DORMANT / SUSPENDED / CLOSED / FROZEN']
  마이너스한도            decimal(15,2) [note: '마이너스 통장 한도 (OVERDRAFT 전용. NULL=해당없음)']
  잔액                    decimal(15,2) [not null, default: 0, note: 'OVERDRAFT는 음수 가능 (-한도 이상)']
  통화코드                char(3)       [not null, default: 'KRW']
  개설일                  varchar(8)   [not null, default: `CURRENT_DATE`]
  해지일                  date
  최종거래일시            timestamptz

  계좌목적                       varchar(20)   [note: 'GENERAL / SALARY / SAVINGS / UTILITY / BUSINESS / INVESTMENT']

  // 해지 권한
  본인외해지허용여부             boolean       [not null, default: false, note: '대리인·법정대리인 해지 허용 여부']

  // 표시 설정
  숨김여부                       boolean       [not null, default: false]
  표시순서                       smallint      [not null, default: 0]

  // 보안
  잠금여부                       boolean       [not null, default: false]
  비밀번호오류횟수               smallint      [not null, default: 0]
  잠금일시                       timestamptz   [note: '잠금 발생 시각']

  // 이체한도 (NULL이면 individual 기본값 적용)
  건별이체한도                   decimal(15,2)
  일일이체한도                   decimal(15,2)

  생성자ID    uuid
  수정자ID    uuid
  생성일시    timestamptz [not null, default: `now()`]
  수정일시    timestamptz [not null, default: `now()`]

  indexes {
    당사자ID
    계약ID
    계좌상태
  }
}

// 적금
Table 적금납입 {
  적금납입ID      uuid          [pk, default: `gen_random_uuid()`]
  계약ID          uuid          [not null, ref: > 계약.계약ID]
  계좌ID          uuid          [not null, ref: > 계좌.계좌ID]

  납입회차        smallint      [not null, note: '납입 회차 (1부터 시작)']
  예정납입일      varchar(8)   [not null, note: '예정 납입일']
  약정납입금액    decimal(15,2) [not null, note: '약정 납입금액']

  실제납입일      varchar(8)   [note: '실제 납입일']
  실제납입금액    decimal(15,2) [note: '실제 납입금액']
  거래ID          uuid          [ref: > 거래내역.거래ID, note: '실제 거래 연결 (NULL=미납)']

  납입상태        varchar(20)   [not null, default: 'SCHEDULED', note: 'SCHEDULED / PAID / PARTIAL / MISSED']

  생성자ID        uuid
  수정자ID        uuid
  생성일시        timestamptz   [not null, default: `now()`]
  수정일시        timestamptz   [not null, default: `now()`]

  indexes {
    (계좌ID, 납입회차) [unique]
    계약ID
    계좌ID
    납입상태
  }
}

Table 거래실행지시 {
  거래실행지시ID        uuid          [pk, default: `gen_random_uuid()`]

  거래지시유형          varchar(30)   [not null, note: 'BULK_TRANSFER / NETWORK_INBOUND / NETWORK_OUTBOUND / AUTO_DEBIT / SCHEDULED']
  거래지시상태          varchar(20)   [not null, default: 'PENDING', note: 'PENDING / PROCESSING / COMPLETED / PARTIAL / FAILED / CANCELLED']
  이체구분          varchar(10)   [note: 'INTERBANK=타행이체 / INTRABANK=당행이체']
  공동망구분        varchar(20)   [note: 'KFTC / CD_NETWORK / CMS / GIRO / INTERNAL']
  전문일련번호      varchar(50)   [note: '공동망 전문 일련번호']
  공동망응답코드    varchar(10)   [note: '게이트웨이 응답코드 (오픈뱅킹: A0000 / 기존망: 00)']
  수취은행응답코드  varchar(10)   [note: '수취은행 응답코드 (오픈뱅킹: bank_rsp_code)']

  총건수            int
  성공건수          int           [not null, default: 0]
  실패건수          int           [not null, default: 0]
  총금액            decimal(15,2)

  제출자ID          uuid          [ref: > 당사자.당사자ID]
  승인자ID          uuid          [ref: > 당사자.당사자ID]
  승인일시          timestamptz

  예정실행일시      timestamptz
  실제실행일시      timestamptz

  적요              varchar(200)

  생성자ID          uuid
  수정자ID          uuid
  생성일시          timestamptz   [not null, default: `now()`]
  수정일시          timestamptz   [not null, default: `now()`]

  indexes {
    거래지시유형
    거래지시상태
    공동망구분
  }
}

Table KFTC수신이력 {
  수신이력ID          uuid          [pk, default: `gen_random_uuid()`]
  거래실행지시ID      uuid          [not null, ref: > 거래실행지시.거래실행지시ID]

  응답코드            varchar(10)   [not null, note: '오픈뱅킹 응답코드 (A0000=정상)']
  응답메시지          varchar(200)
  수취은행응답코드    varchar(10)
  수취은행응답메시지  varchar(200)
  핀테크이용번호      varchar(30)
  은행거래고유번호    varchar(30)   [note: 'KFTC 채번 (예: M202607010001)']

  수신일시            timestamptz   [not null, default: `now()`]

  생성자ID            uuid
  수정자ID            uuid
  생성일시            timestamptz   [not null, default: `now()`]
  수정일시            timestamptz   [not null, default: `now()`]

  indexes {
    거래실행지시ID
    은행거래고유번호
  }
}

Table 거래내역 {
  거래ID                  uuid          [pk, default: `gen_random_uuid()`]
  계좌ID                  uuid          [not null, ref: > 계좌.계좌ID]

  거래유형                varchar(20)   [not null, note: 'DEPOSIT / WITHDRAWAL / TRANSFER_OUT / TRANSFER_IN / INTEREST / FEE']
  거래금액                decimal(15,2) [not null]
  거래전잔액              decimal(15,2) [not null]
  거래후잔액              decimal(15,2) [not null]

  거래상태                    varchar(20)   [not null, default: 'COMPLETED', note: 'COMPLETED / PENDING / FAILED / CANCELLED']
  거래채널                    varchar(20)   [note: 'APP / ATM / TELLER / INTERNET / AUTO / SCHEDULED']

  상대방계좌번호          varchar(30)
  상대방은행코드          varchar(10)
  상대방명                varchar(100)
  상대방당사자ID          uuid          [ref: > 당사자.당사자ID, note: '내부 고객인 경우 party 연결']
  상대방계좌ID            uuid          [ref: > 계좌.계좌ID, note: '동행 이체 시 계좌 직접 연결']
  송금은행코드            varchar(10)   [note: '송금인 은행 코드 (상대방은행코드=수취인 은행과 구분)']
  받는사람표시            varchar(20)
  보내는사람표시          varchar(20)

  거래번호                varchar(30)   [unique, note: '고객용 거래번호 (영수증·명세서 표시, 예: 20260515-000123)']
  거래키                  varchar(50)   [unique, note: '외부 시스템 통합용 고유 거래 키']
  참조번호                varchar(50)   [note: '금융결제원 거래 참조번호']
  거래실행지시ID              uuid          [ref: > 거래실행지시.거래실행지시ID, note: '대량이체·공동망 지시 연결']

  세금금액                decimal(15,2) [note: '이자소득세 등']

  이체방식                varchar(20)   [note: 'REALTIME / AGGREGATE / NIGHT / SAME_DAY']
  결제일                  varchar(8)   [note: '거래일자와 결제일이 다를 경우 (익영업일 결제 등)']

  승인자ID                uuid          [ref: > 직원.직원ID]
  승인일시                timestamptz
  거절사유                varchar(200)

  재시도횟수              smallint      [not null, default: 0]

  리스크스코어            decimal(5,2)
  이상거래여부            boolean       [not null, default: false]
  IP주소                  inet
  기기식별자              varchar(100)

  적요                    varchar(200)
  사용자메모              text          [note: '고객 입력 메모 (적요보다 긴 메모용)']

  거래일자                varchar(8)   [not null, default: `CURRENT_DATE`]
  거래일시                timestamptz   [not null, default: `now()`]

  생성자ID                uuid
  수정자ID                uuid
  생성일시                timestamptz   [not null, default: `now()`]
  수정일시                timestamptz   [not null, default: `now()`]

  indexes {
    계좌ID
    (거래일시)
    거래유형
    거래키 [unique]
    거래실행지시ID
    이상거래여부
    결제일
  }
}


// ============================================================
// 기업뱅킹 도메인


// ============================================================
// 인프라·조직 도메인
// ============================================================

Table 지점 {
  지점ID       uuid         [pk, default: `gen_random_uuid()`]
  지점코드     varchar(10)  [not null, unique, note: '점포코드 (금융결제원 기준)']
  지점명       varchar(100) [not null]
  지점유형     varchar(20)  [not null, note: 'HEAD_OFFICE / BRANCH / SUB_BRANCH']
  지점상태     varchar(20)  [not null, default: 'ACTIVE', note: 'ACTIVE / CLOSED / SUSPENDED']

  우편번호     varchar(5)
  주소         varchar(200)
  상세주소     varchar(100)

  전화번호     varchar(20)
  팩스번호     varchar(20)

  영업시작시간 time         [note: '예: 09:00']
  영업종료시간 time         [note: '예: 16:00']

  개점일       date
  폐점일       date

  생성자ID     uuid
  수정자ID     uuid
  생성일시     timestamptz  [not null, default: `now()`]
  수정일시     timestamptz  [not null, default: `now()`]

  indexes {
    지점상태
    지점유형
  }
}


Table 직원 {
  직원ID       uuid         [pk, default: `gen_random_uuid()`]
  지점ID       uuid         [not null, ref: > 지점.지점ID]
  당사자ID     uuid         [ref: > 당사자.당사자ID, note: 'NULL=은행 고객이 아닌 직원']

  사번         varchar(20)  [not null, unique]
  이름         varchar(100) [not null]
  부서         varchar(100)
  직위         varchar(50)

  이메일       varchar(200)
  전화번호     varchar(20)

  직원상태     varchar(20)  [not null, default: 'ACTIVE', note: 'ACTIVE / ON_LEAVE / RESIGNED']
  입사일       varchar(8)  [not null]
  퇴사일       date

  생성자ID     uuid
  수정자ID     uuid
  생성일시     timestamptz  [not null, default: `now()`]
  수정일시     timestamptz  [not null, default: `now()`]

  indexes {
    지점ID
    사번
  }
}


// ============================================================
// 파일·문서 도메인
// ============================================================

Table 문서 {
  문서ID          uuid          [pk, default: `gen_random_uuid()`]

  // 파일 저장 정보
  원본파일명      varchar(255)  [not null]
  저장파일명      varchar(255)
  파일URL         text          [not null, note: 'S3 등 스토리지 경로']
  파일크기        bigint        [note: 'bytes']
  MIME타입        varchar(100)

  업로드상태      varchar(20)   [not null, default: 'COMPLETED', note: 'PENDING / COMPLETED / FAILED']

  업로더당사자ID  uuid          [ref: > 당사자.당사자ID]
  업로드일시      timestamptz   [not null, default: `now()`]

  연결대상유형    varchar(30)   [not null, note: 'LOAN_APPLICATION / CONTRACT / ACCOUNT / KYC / OTHER']
  연결대상ID      uuid          [not null, note: '연결 대상 PK (entity_type에 따라 참조 테이블 다름)']

  문서유형        varchar(50)   [not null, note: 'ID_CARD / LOAN_APPLICATION_FORM / DEBT_STATEMENT / INCOME_PROOF / CREDIT_INFO_CONSENT / EMPLOYMENT_CERT / PROPERTY_CERT / TAX_RETURN / BANK_STATEMENT / CONTRACT_COPY / OTHER']

  확인여부        boolean       [not null, default: false]
  확인직원ID      uuid          [ref: > 직원.직원ID]
  확인일시        timestamptz

  제출일시        timestamptz   [not null, default: `now()`]
  제출자당사자ID  uuid          [ref: > 당사자.당사자ID]

  생성자ID        uuid
  수정자ID        uuid
  생성일시        timestamptz   [not null, default: `now()`]
  수정일시        timestamptz   [not null, default: `now()`]

  indexes {
    (연결대상유형, 연결대상ID)
    업로더당사자ID
  }
}


// ============================================================
// 대출 신청 프로세스 도메인
// ============================================================

Table 대출신청 {
  신청ID              uuid          [pk, default: `gen_random_uuid()`]
  당사자ID            uuid          [not null, ref: > 당사자.당사자ID]
  상품ID              uuid          [not null, ref: > 상품.상품ID]

  신청금액            decimal(15,2) [not null]
  신청기간월수        int
  대출목적            varchar(100)

  // 본인 확인
  본인확인여부        boolean       [not null, default: false]
  대리권유무          boolean
  대리인ID            uuid          [ref: > 당사자.당사자ID, note: '본인 신청 시 NULL']
  신용조사위탁여부    boolean       [not null, default: false, note: 'FALSE=영업점 자체 / TRUE=심사부서 위탁']

  신청상태            varchar(20)   [not null, default: 'DRAFT', note: 'DRAFT / SUBMITTED / CREDIT_CHECK / REVIEWING / APPROVED / PRE_EXECUTION / REJECTED / EXECUTED / CANCELLED']

  승인금액            decimal(15,2)
  승인금리            decimal(7,4)
  거절사유            varchar(500)

  // 심사 검토 항목
  신용심사결과        text          [note: '차주 적격성 (자격, 신용상태, 거래상황)']
  자금적정성검토      text          [note: '소요자금 적정성']
  담보검토            text          [note: '채권보전 방법 (보증인, 담보)']
  기여도검토          text          [note: '기여도 및 금리']
  여신등급            varchar(10)   [note: 'A / B / C / D 등']

  // 전결권자
  전결권자ID          uuid          [ref: > 직원.직원ID]
  승인일시            timestamptz

  계약ID              uuid          [ref: > 계약.계약ID, note: '실행 후 연결']

  신청채널            varchar(20)   [note: 'APP / INTERNET / BRANCH / PHONE']
  지점ID              uuid          [ref: > 지점.지점ID]
  담당직원ID          uuid          [ref: > 직원.직원ID]

  // 상담 기록
  상담일              date
  상담메모            text

  제출일시            timestamptz
  결정일시            timestamptz

  생성자ID            uuid
  수정자ID            uuid
  생성일시            timestamptz   [not null, default: `now()`]
  수정일시            timestamptz   [not null, default: `now()`]

  indexes {
    당사자ID
    상품ID
    신청상태
  }
}

Table 대출심사단계 {
  단계ID          uuid         [pk, default: `gen_random_uuid()`]
  신청ID          uuid         [not null, ref: > 대출신청.신청ID]

  단계순서        smallint     [not null, note: '1부터 시작']
  심사직원ID      uuid         [not null, ref: > 직원.직원ID]

  단계상태        varchar(20)  [not null, default: 'PENDING', note: 'PENDING / APPROVED / REJECTED / SKIPPED']
  의견            text
  결정일시        timestamptz

  // 전결 권한
  전결권한레벨    int           [note: '높을수록 상위 결재권자']
  전결권자직급    varchar(100)  [note: '스냅샷']

  생성자ID        uuid
  수정자ID        uuid
  생성일시        timestamptz  [not null, default: `now()`]
  수정일시        timestamptz  [not null, default: `now()`]

  indexes {
    (신청ID, 단계순서) [unique]
    신청ID
  }
}

Table 대출담보 {
  담보ID          uuid          [pk, default: `gen_random_uuid()`]
  신청ID          uuid          [not null, ref: > 대출신청.신청ID]

  담보유형        varchar(30)   [not null, note: 'REAL_ESTATE / DEPOSIT / SECURITIES / VEHICLE / OTHER']

  소재지          varchar(300)  [note: '부동산 담보 전용']
  등기번호        varchar(30)   [note: '부동산 등기번호']

  감정가          decimal(15,2)
  감정기준일      date
  감정기관명      varchar(100)
  근저당설정금액  decimal(15,2)

  // 담보 평가 이력
  자체평가여부    boolean       [not null, default: false, note: 'FALSE=집중화센터 위탁 / TRUE=영업점 자체평가']
  감정요청일시    timestamptz
  감정완료일시    timestamptz
  저당권설정일    date
  저당권등기번호  varchar(50)
  채권보전확인    boolean       [not null, default: false, note: '채권보전(저당권설정) 완료 확인 — 여신실행 전 true여야 함']

  생성자ID        uuid
  수정자ID        uuid
  생성일시        timestamptz   [not null, default: `now()`]
  수정일시        timestamptz   [not null, default: `now()`]

  indexes {
    신청ID
  }
}


Table 대출연체 {
  연체ID          uuid          [pk, default: `gen_random_uuid()`]
  계약ID          uuid          [not null, ref: > 계약.계약ID]

  연체상태        varchar(20)   [not null, note: 'OVERDUE=연체 / DEFAULT=부도 / RECOVERED=정상화']

  연체원금        decimal(15,2) [not null, default: 0]
  연체이자        decimal(15,2) [not null, default: 0]
  연체일수        int           [not null]

  연체시작일      varchar(8)   [not null]
  정상화일        varchar(8)   [note: 'NULL=현재 연체 중']

  // 사후관리
  유용의심여부    boolean       [not null, default: false, note: '용도 외 유용']
  유용내용        text
  회수방식        varchar(20)   [note: 'SELF=자기회수 / GUARANTEE=보증인회수 / LEGAL=법적회수 / WRITE_OFF=파산정리']
  연장이력        json          [note: '기간 연장 이력']

  생성자ID        uuid
  수정자ID        uuid
  생성일시        timestamptz   [not null, default: `now()`]
  수정일시        timestamptz   [not null, default: `now()`]

  indexes {
    계약ID
    연체상태
  }
}
