// ============================================================
// 13. 계좌 마스터
// ============================================================
model Account {
  accountId                  String    @id @default(dbgenerated("gen_random_uuid()")) @map("account_id") @db.Uuid
  accountNumber              String    @unique @map("account_number") @db.VarChar(30)
  accountPasswordHash        String    @map("account_password_hash") @db.VarChar(60)
  partyId                    String    @map("party_id") @db.Uuid
  contractId                 String?   @map("contract_id") @db.Uuid
  accountType                String    @map("account_type") @db.VarChar(20)
  accountStatus              String    @default("ACTIVE") @map("account_status") @db.VarChar(20)
  balance                    Decimal   @default(0) @db.Decimal(15, 2)
  currencyCode               String    @default("KRW") @map("currency_code") @db.Char(3)
  openedDate                 String    @map("opened_date") @db.VarChar(10)
  closedDate                 String?   @map("closed_date") @db.VarChar(10)
  lastTransactionAt          DateTime? @map("last_transaction_at") @db.Timestamptz()
  accountPurpose             String?   @map("account_purpose") @db.VarChar(20)
  isThirdPartyClosureAllowed Boolean   @default(false) @map("is_third_party_closure_allowed")
  isHidden                   Boolean   @default(false) @map("is_hidden")
  displayOrder               Int       @default(0) @map("display_order") @db.SmallInt
  isLocked                   Boolean   @default(false) @map("is_locked")
  passwordFailCount          Int       @default(0) @map("password_fail_count") @db.SmallInt
  lockedAt                   DateTime? @map("locked_at") @db.Timestamptz()
  transferLimitPerTransaction Decimal? @map("transfer_limit_per_transaction") @db.Decimal(15, 2)
  transferLimitPerDay        Decimal?  @map("transfer_limit_per_day") @db.Decimal(15, 2)
  createdBy                  String?   @map("created_by") @db.Uuid
  updatedBy                  String?   @map("updated_by") @db.Uuid
  createdAt                  DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  party    Party     @relation(fields: [partyId], references: [partyId])
  contract Contract? @relation(fields: [contractId], references: [contractId])

  // Transaction에서 account_id, counterparty_account_id 두 FK가 모두 Account를 참조하므로 명시적 relation name 필요
  transactions             Transaction[] @relation("AccountTxns")
  counterpartyTxns         Transaction[] @relation("CounterpartyAccountTxns")
  savingsPayments          SavingsPayment[]
  accountMappings          AccountMapping[]

  @@index([partyId], map: "idx_account_party_id")
  @@index([contractId], map: "idx_account_contract_id")
  @@index([accountStatus], map: "idx_account_status")
  @@map("account")
}

// ============================================================
// 14. 거래 내역
// ============================================================
model Transaction {
  transactionId           String    @id @default(dbgenerated("gen_random_uuid()")) @map("transaction_id") @db.Uuid
  accountId               String    @map("account_id") @db.Uuid
  transactionType         String    @map("transaction_type") @db.VarChar(20)
  amount                  Decimal   @db.Decimal(15, 2)
  balanceBefore           Decimal   @map("balance_before") @db.Decimal(15, 2)
  balanceAfter            Decimal   @map("balance_after") @db.Decimal(15, 2)
  transactionStatus       String    @default("COMPLETED") @map("transaction_status") @db.VarChar(20)
  channel                 String?   @db.VarChar(20)
  counterpartAccountNumber String?  @map("counterpart_account_number") @db.VarChar(30)
  counterpartBankCode     String?   @map("counterpart_bank_code") @db.VarChar(10)
  counterpartName         String?   @map("counterpart_name") @db.VarChar(100)
  counterpartyPartyId     String?   @map("counterparty_party_id") @db.Uuid
  counterpartyAccountId   String?   @map("counterparty_account_id") @db.Uuid
  bankCode                String?   @map("bank_code") @db.VarChar(10)
  transferer              String?   @db.VarChar(20)
  remitter                String?   @db.VarChar(20)
  transactionNo           String?   @unique @map("transaction_no") @db.VarChar(30)
  transactionKey          String?   @unique @map("transaction_key") @db.VarChar(50)
  referenceNo             String?   @map("reference_no") @db.VarChar(50)
  batchId                 String?   @map("batch_id") @db.Uuid
  feeAmount               Decimal?  @map("fee_amount") @db.Decimal(15, 2)
  taxAmount               Decimal?  @map("tax_amount") @db.Decimal(15, 2)
  transferMethod          String?   @map("transfer_method") @db.VarChar(20)
  settlementDate          String?   @map("settlement_date") @db.VarChar(10)
  approvedBy              String?   @map("approved_by") @db.Uuid
  approvedAt              DateTime? @map("approved_at") @db.Timestamptz()
  rejectedReason          String?   @map("rejected_reason") @db.VarChar(200)
  riskScore               Decimal?  @map("risk_score") @db.Decimal(5, 2)
  riskFlag                Boolean   @default(false) @map("risk_flag")
  // INET 타입: Prisma는 String으로 매핑, DB 레벨에서 INET 유지
  ipAddress               String?   @map("ip_address")
  deviceFingerprint       String?   @map("device_fingerprint") @db.VarChar(100)
  remark                  String?   @db.VarChar(200)
  memo                    String?   @db.Text
  transactionDate         String    @map("transaction_date") @db.VarChar(10)
  transactedAt            DateTime  @default(now()) @map("transacted_at") @db.Timestamptz()
  createdBy               String?   @map("created_by") @db.Uuid
  updatedBy               String?   @map("updated_by") @db.Uuid
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt               DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  account             Account   @relation("AccountTxns", fields: [accountId], references: [accountId])
  counterpartyParty   Party?    @relation("CounterpartyPartyTxns", fields: [counterpartyPartyId], references: [partyId])
  counterpartyAccount Account?  @relation("CounterpartyAccountTxns", fields: [counterpartyAccountId], references: [accountId])
  approver            Employee? @relation(fields: [approvedBy], references: [employeeId])
  savingsPayments     SavingsPayment[]

  @@index([accountId], map: "idx_transaction_account_id")
  @@index([transactedAt(sort: Desc)], map: "idx_transaction_transacted_at")
  @@index([transactionType], map: "idx_transaction_type")
  @@index([referenceNo], map: "idx_transaction_reference_no")
  @@index([batchId], map: "idx_transaction_batch_id")
  @@index([riskFlag], map: "idx_transaction_risk_flag")
  @@index([settlementDate], map: "idx_transaction_settlement")
  @@map("transaction")
}

// ============================================================
