}

// ============================================================
// 25. 문서 (파일 저장 + 범용 첨부 — 대출·계약·KYC 등)
// ============================================================
model Document {
  documentId        String    @id @default(dbgenerated("gen_random_uuid()")) @map("document_id") @db.Uuid
  originalName      String    @map("original_name") @db.VarChar(255)
  storedName        String?   @map("stored_name") @db.VarChar(255)
  fileUrl           String    @map("file_url") @db.Text
  fileSize          BigInt?   @map("file_size")
  mimeType          String?   @map("mime_type") @db.VarChar(100)
  uploadStatus      String    @default("COMPLETED") @map("upload_status") @db.VarChar(20)
  uploadedBy        String?   @map("uploaded_by") @db.Uuid
  uploadedAt        DateTime  @default(now()) @map("uploaded_at") @db.Timestamptz()
  entityType        String    @map("entity_type") @db.VarChar(30)   // LOAN_APPLICATION | CONTRACT | ACCOUNT | KYC | OTHER
  entityId          String    @map("entity_id") @db.Uuid             // 연결 대상 PK (폴리모픽)
  documentType      String    @map("document_type") @db.VarChar(50)
  verified          Boolean   @default(false)
  verifiedBy        String?   @map("verified_by") @db.Uuid
  verifiedAt        DateTime? @map("verified_at") @db.Timestamptz()
  submittedAt       DateTime  @default(now()) @map("submitted_at") @db.Timestamptz()
  submitterPartyId  String?   @map("submitter_party_id") @db.Uuid
  createdBy         String?   @map("created_by") @db.Uuid
  updatedBy         String?   @map("updated_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  uploader  Party?    @relation("DocumentUploadedBy", fields: [uploadedBy], references: [partyId])
  submitter Party?    @relation("DocumentSubmittedBy", fields: [submitterPartyId], references: [partyId])
  verifier  Employee? @relation(fields: [verifiedBy], references: [employeeId])

  @@index([entityType, entityId], map: "idx_document_entity")
  @@index([uploadedBy], map: "idx_document_uploaded_by")
  @@index([submitterPartyId], map: "idx_document_submitter")
  @@map("document")
}

// ============================================================
// 27. 대출 신청 프로세스
