  @@map("loan_application")
}

model LoanApprovalStep {
  stepId        String    @id @default(dbgenerated("gen_random_uuid()")) @map("step_id") @db.Uuid
  applicationId String    @map("application_id") @db.Uuid
  stepNo        Int       @map("step_no") @db.SmallInt
  employeeId    String    @map("employee_id") @db.Uuid
  stepStatus    String    @default("PENDING") @map("step_status") @db.VarChar(20)
  comment       String?   @db.Text
  decidedAt     DateTime? @map("decided_at") @db.Timestamptz()
  authorityLevel Int?     @map("authority_level")
  authorityName  String?  @map("authority_name") @db.VarChar(100)
  createdBy     String?   @map("created_by") @db.Uuid
  updatedBy     String?   @map("updated_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  application LoanApplication @relation(fields: [applicationId], references: [applicationId])
  employee    Employee        @relation(fields: [employeeId], references: [employeeId])

  @@unique([applicationId, stepNo], map: "uq_loan_approval_step")
  @@index([applicationId], map: "idx_loan_approval_step_application")
  @@map("loan_approval_step")
}

model LoanCollateral {
  collateralId          String    @id @default(dbgenerated("gen_random_uuid()")) @map("collateral_id") @db.Uuid
  applicationId         String    @map("application_id") @db.Uuid
  collateralType        String    @map("collateral_type") @db.VarChar(30)
  propertyAddress       String?   @map("property_address") @db.VarChar(300)
  propertyRegNo         String?   @map("property_reg_no") @db.VarChar(30)
  appraisedValue        Decimal?  @map("appraised_value") @db.Decimal(15, 2)
  appraisedAt           String?   @map("appraised_at") @db.VarChar(8)
  appraiser             String?   @db.VarChar(100)
  selfAppraised         Boolean   @default(false) @map("self_appraised")
  appraisalRequestedAt  DateTime? @map("appraisal_requested_at") @db.Timestamptz()
  appraisalCompletedAt  DateTime? @map("appraisal_completed_at") @db.Timestamptz()
  lienAmount            Decimal?  @map("lien_amount") @db.Decimal(15, 2)
  lienRegisteredAt      String?   @map("lien_registered_at") @db.VarChar(8)
  lienRegNo             String?   @map("lien_reg_no") @db.VarChar(50)
  lienConfirmed         Boolean   @default(false) @map("lien_confirmed")
  createdBy             String?   @map("created_by") @db.Uuid
  updatedBy             String?   @map("updated_by") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  application LoanApplication @relation(fields: [applicationId], references: [applicationId])

  @@index([applicationId], map: "idx_loan_collateral_application")
  @@map("loan_collateral")
}

model LoanDelinquency {
  delinquencyId     String   @id @default(dbgenerated("gen_random_uuid()")) @map("delinquency_id") @db.Uuid
  contractId        String   @map("contract_id") @db.Uuid
  delinquencyStatus String   @map("delinquency_status") @db.VarChar(20)
  overduePrincipal  Decimal  @default(0) @map("overdue_principal") @db.Decimal(15, 2)
  overdueInterest   Decimal  @default(0) @map("overdue_interest") @db.Decimal(15, 2)
  overdueDays       Int      @map("overdue_days")
  startedAt         DateTime @map("started_at") @db.Date
  recoveredAt       String?  @map("recovered_at") @db.VarChar(8)
  fundMisuseFlag    Boolean  @default(false) @map("fund_misuse_flag")
  fundMisuseDetail  String?  @map("fund_misuse_detail") @db.Text
  collectionMethod  String?  @map("collection_method") @db.VarChar(20)
  extensionHistory  Json?    @map("extension_history") @db.JsonB
  createdBy         String?  @map("created_by") @db.Uuid
  updatedBy         String?  @map("updated_by") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  contract Contract @relation(fields: [contractId], references: [contractId])

  @@index([contractId], map: "idx_loan_delinquency_contract")
  @@index([delinquencyStatus], map: "idx_loan_delinquency_status")
  @@map("loan_delinquency")
}

// ============================================================
// 28. 알림
// ============================================================
model Notification {
  notificationId String   @id @default(dbgenerated("gen_random_uuid()")) @map("notification_id") @db.Uuid
  partyId        String   @map("party_id") @db.Uuid
  notificationType  String   @map("notification_type") @db.VarChar(50)
  notificationTitle String   @map("notification_title") @db.VarChar(200)
  notificationBody  String   @map("notification_body") @db.VarChar(500)
  isRead         Boolean  @default(false) @map("is_read")
  linkedEntityId String?  @map("linked_entity_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  party Party @relation(fields: [partyId], references: [partyId])

  @@index([partyId, isRead], map: "idx_notification_party_read")
  @@index([createdAt(sort: Desc)], map: "idx_notification_created_at")
  @@map("notification")
}

// ============================================================
// 29. 자동이체
// ============================================================
model ScheduledTransfer {
  scheduledTransferId String   @id @default(dbgenerated("gen_random_uuid()")) @map("scheduled_transfer_id") @db.Uuid
  partyId             String   @map("party_id") @db.Uuid
  fromAccountId       String   @map("from_account_id") @db.Uuid
  toBankCode          String   @map("to_bank_code") @db.VarChar(10)
  toAccountNumber     String   @map("to_account_number") @db.VarChar(30)
  toAccountName       String   @map("to_account_name") @db.VarChar(100)
  amount              Decimal  @db.Decimal(15, 2)
  memo                String?  @db.VarChar(200)
  transferDay         Int      @map("transfer_day") @db.SmallInt
  startDate           String   @map("start_date") @db.VarChar(8)
  endDate             String?  @map("end_date") @db.VarChar(8)
  status              String   @default("ACTIVE") @map("status") @db.VarChar(20)
  lastExecutedDate    String?  @map("last_executed_date") @db.VarChar(8)
  nextExecutionDate   String?  @map("next_execution_date") @db.VarChar(8)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  party       Party   @relation(fields: [partyId], references: [partyId])
  fromAccount Account @relation(fields: [fromAccountId], references: [accountId])
  executions  ScheduledTransferExecution[]

  @@index([partyId], map: "idx_scheduled_transfer_party")
  @@index([status, nextExecutionDate], map: "idx_scheduled_transfer_active")
  @@map("scheduled_transfer")
}

model ScheduledTransferExecution {
  executionId         String   @id @default(dbgenerated("gen_random_uuid()")) @map("execution_id") @db.Uuid
  scheduledTransferId String   @map("scheduled_transfer_id") @db.Uuid
  transactionId       String?  @map("transaction_id") @db.Uuid
  executionDate       String   @map("execution_date") @db.VarChar(8)
  status              String   @map("status") @db.VarChar(20)
  failureReason       String?  @map("failure_reason") @db.VarChar(200)
  executedAt          DateTime @default(now()) @map("executed_at") @db.Timestamptz()

  scheduledTransfer ScheduledTransfer @relation(fields: [scheduledTransferId], references: [scheduledTransferId])

  @@index([scheduledTransferId], map: "idx_ste_scheduled")
  @@map("scheduled_transfer_execution")
}

// ============================================================
// 30. RAG 문서 청크 (pgvector)
// embedding 컬럼은 Unsupported — $queryRaw로만 접근
// ============================================================
model DocumentChunk {
  id           String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  docName      String                      @map("doc_name")
  articleNum   String?                     @map("article_num")
  sectionNum   String?                     @map("section_num")
  content      String
  metadata     Json                        @default("{}")
  embedding    Unsupported("vector(768)")?
  qualityScore Float                       @default(1.0) @map("quality_score")
  createdAt    DateTime                    @default(now()) @map("created_at") @db.Timestamptz()

  @@index([docName], map: "idx_doc_chunk_doc_name")
  @@map("document_chunks")
}

// ============================================================
// 31. 채팅 피드백 (RAG 청크 품질 개선용)
// ============================================================
model ChatFeedback {
  feedbackId String   @id @default(dbgenerated("gen_random_uuid()")) @map("feedback_id") @db.Uuid
  chunkIds   String[] @map("chunk_ids") @db.Uuid
  feedback   String?  @db.VarChar(4)
  question   String   @default("")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("chat_feedback")
}
