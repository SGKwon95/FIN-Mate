// ============================================================
// 11. 계약
// ============================================================
model Contract {
  contractId           String   @id @default(dbgenerated("gen_random_uuid()")) @map("contract_id") @db.Uuid
  partyId              String   @map("party_id") @db.Uuid
  productId            String   @map("product_id") @db.Uuid
  contractDate         String   @map("contract_date") @db.VarChar(8)
  executionDate        String?  @map("execution_date") @db.VarChar(8)
  maturityDate         String?  @map("maturity_date") @db.VarChar(8)
  endDate              String?  @map("end_date") @db.VarChar(8)
  contractPeriodMonths Int?     @map("contract_period_months") @db.SmallInt
  contractAmount       Decimal? @map("contract_amount") @db.Decimal(15, 2)
  stampDuty            Decimal? @map("stamp_duty") @db.Decimal(15, 2)
  contractStatus       String   @default("ACTIVE") @map("contract_status") @db.VarChar(25)
  appliedRate          Decimal  @map("applied_rate") @db.Decimal(7, 4)
  branchId             String?  @map("branch_id") @db.Uuid
  employeeId           String?  @map("employee_id") @db.Uuid
  employeeName         String?  @map("employee_name") @db.VarChar(100)
  contractDocumentUrl  String?  @map("contract_document_url") @db.Text
  createdBy            String?  @map("created_by") @db.Uuid
  updatedBy            String?  @map("updated_by") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  party           Party                    @relation(fields: [partyId], references: [partyId])
  product         Product                  @relation(fields: [productId], references: [productId])
  branch          Branch?                  @relation(fields: [branchId], references: [branchId])
  employee        Employee?                @relation(fields: [employeeId], references: [employeeId])
  accounts        Account[]
  termsAgreements ContractTermsAgreement[]
  rateBenefits    ContractRateBenefit[]
  loanApplications LoanApplication[]
  delinquencies   LoanDelinquency[]
  savingsPayments SavingsPayment[]

  @@index([partyId], map: "idx_contract_party")
  @@index([productId], map: "idx_contract_product")
  @@index([contractStatus], map: "idx_contract_status")
  @@index([branchId], map: "idx_contract_branch_id")
  @@map("contract")
}

// ============================================================
// 12. 약관 동의 이력
// ============================================================
model ContractTermsAgreement {
  contractId      String   @map("contract_id") @db.Uuid
  termsId         String   @map("terms_id") @db.Uuid
  agreedAt        DateTime @default(now()) @map("agreed_at") @db.Timestamptz()
  agreementMethod String   @map("agreement_method") @db.VarChar(20)  // APP | PAPER | KIOSK
  contractMethod  String?  @map("contract_method") @db.VarChar(20)   // REMOTE | IN_PERSON | HYBRID
