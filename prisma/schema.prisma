  @@map("contract_rate_benefit")
}

// ============================================================
// 13. 계좌 마스터
// ============================================================
model Account {
  accountId                  String    @id @default(dbgenerated("gen_random_uuid()")) @map("account_id") @db.Uuid
  accountNumber              String    @unique @map("account_number") @db.VarChar(30)
  accountPasswordHash        String    @map("account_password_hash") @db.VarChar(60)
  partyId                    String    @map("party_id") @db.Uuid
  contractId                 String?   @map("contract_id") @db.Uuid
  accountType                String    @map("account_type") @db.VarChar(20)
  accountStatus              String    @default("ACTIVE") @map("account_status") @db.VarChar(20)
  creditLimit                Decimal?  @map("credit_limit") @db.Decimal(15, 2)  // 마이너스통장 한도
  balance                    Decimal   @default(0) @db.Decimal(15, 2)
  currencyCode               String    @default("KRW") @map("currency_code") @db.Char(3)
  openedDate                 String    @map("opened_date") @db.VarChar(8)
  closedDate                 String?   @map("closed_date") @db.VarChar(8)
  lastTransactionAt          DateTime? @map("last_transaction_at") @db.Timestamptz()
  accountPurpose             String?   @map("account_purpose") @db.VarChar(20)
  isThirdPartyClosureAllowed Boolean   @default(false) @map("is_third_party_closure_allowed")
  isHidden                   Boolean   @default(false) @map("is_hidden")
  displayOrder               Int       @default(0) @map("display_order") @db.SmallInt
  isLocked                   Boolean   @default(false) @map("is_locked")
  passwordFailCount          Int       @default(0) @map("password_fail_count") @db.SmallInt
  lockedAt                   DateTime? @map("locked_at") @db.Timestamptz()
  transferLimitPerTransaction Decimal? @map("transfer_limit_per_transaction") @db.Decimal(15, 2)
  transferLimitPerDay        Decimal?  @map("transfer_limit_per_day") @db.Decimal(15, 2)
  createdBy                  String?   @map("created_by") @db.Uuid
  updatedBy                  String?   @map("updated_by") @db.Uuid
  createdAt                  DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  party    Party     @relation(fields: [partyId], references: [partyId])
  contract Contract? @relation(fields: [contractId], references: [contractId])

  transactions       Transaction[] @relation("AccountTxns")
  counterpartyTxns   Transaction[] @relation("CounterpartyAccountTxns")
  savingsPayments    SavingsPayment[]
  scheduledTransfers ScheduledTransfer[]

  @@index([partyId], map: "idx_account_party_id")
  @@index([contractId], map: "idx_account_contract_id")
  @@index([accountStatus], map: "idx_account_status")
  @@map("account")
}

