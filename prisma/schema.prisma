// ============================================================
// 16. 거래 내역
// ============================================================
model Transaction {
  transactionId            String    @id @default(dbgenerated("gen_random_uuid()")) @map("transaction_id") @db.Uuid
  accountId                String    @map("account_id") @db.Uuid
  transactionType          String    @map("transaction_type") @db.VarChar(20)
  amount                   Decimal   @db.Decimal(15, 2)
  balanceBefore            Decimal   @map("balance_before") @db.Decimal(15, 2)
  balanceAfter             Decimal   @map("balance_after") @db.Decimal(15, 2)
  transactionStatus        String    @default("COMPLETED") @map("transaction_status") @db.VarChar(20)
  channel                  String?   @db.VarChar(20)
  counterpartAccountNumber String?   @map("counterpart_account_number") @db.VarChar(30)
  counterpartBankCode      String?   @map("counterpart_bank_code") @db.VarChar(10)
  counterpartName          String?   @map("counterpart_name") @db.VarChar(100)
  counterpartyPartyId      String?   @map("counterparty_party_id") @db.Uuid
  counterpartyAccountId    String?   @map("counterparty_account_id") @db.Uuid
  bankCode                 String?   @map("bank_code") @db.VarChar(10)
  transferer               String?   @db.VarChar(20)
  remitter                 String?   @db.VarChar(20)
  transactionNo            String?   @unique @map("transaction_no") @db.VarChar(30)
  transactionKey           String?   @unique @map("transaction_key") @db.VarChar(50)
  referenceNo              String?   @map("reference_no") @db.VarChar(50)
  instructionId            String?   @map("instruction_id") @db.Uuid
  taxAmount                Decimal?  @map("tax_amount") @db.Decimal(15, 2)
  transferMethod           String?   @map("transfer_method") @db.VarChar(20)
  settlementDate           String?   @map("settlement_date") @db.VarChar(8)
  approvedBy               String?   @map("approved_by") @db.Uuid
  approvedAt               DateTime? @map("approved_at") @db.Timestamptz()
  rejectedReason           String?   @map("rejected_reason") @db.VarChar(200)
  retryCount               Int       @default(0) @map("retry_count") @db.SmallInt
  riskScore                Decimal?  @map("risk_score") @db.Decimal(5, 2)
  riskFlag                 Boolean   @default(false) @map("risk_flag")
  ipAddress                String?   @map("ip_address")  // INET 타입: DB 레벨 유지
  deviceFingerprint        String?   @map("device_fingerprint") @db.VarChar(100)
  remark                   String?   @db.VarChar(200)
  memo                     String?   @db.Text
  transactionDate          String    @map("transaction_date") @db.VarChar(8)
  transactedAt             DateTime  @default(now()) @map("transacted_at") @db.Timestamptz()
  createdBy                String?   @map("created_by") @db.Uuid
  updatedBy                String?   @map("updated_by") @db.Uuid
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  account             Account              @relation("AccountTxns", fields: [accountId], references: [accountId])
  counterpartyParty   Party?               @relation("CounterpartyPartyTxns", fields: [counterpartyPartyId], references: [partyId])
  counterpartyAccount Account?             @relation("CounterpartyAccountTxns", fields: [counterpartyAccountId], references: [accountId])
  approver            Employee?            @relation(fields: [approvedBy], references: [employeeId])
  instruction         TransferInstruction? @relation(fields: [instructionId], references: [instructionId])
  savingsPayments     SavingsPayment[]
  kftcReceipt         KftcReceipt?

  @@index([accountId], map: "idx_transaction_account_id")
  @@index([transactedAt(sort: Desc)], map: "idx_transaction_transacted_at")
  @@index([transactionType], map: "idx_transaction_type")
  @@index([referenceNo], map: "idx_transaction_reference_no")
  @@index([instructionId], map: "idx_transaction_instruction_id")
  @@index([riskFlag], map: "idx_transaction_risk_flag")
  @@index([settlementDate], map: "idx_transaction_settlement")
  @@map("transaction")
}

// ============================================================
// 16. 적금 납입 회차
// ============================================================
model SavingsPayment {
  savingsPaymentId     String    @id @default(dbgenerated("gen_random_uuid()")) @map("savings_payment_id") @db.Uuid
  contractId           String?   @map("contract_id") @db.Uuid
  accountId            String    @map("account_id") @db.Uuid
  installmentNo        Int       @map("installment_no") @db.SmallInt
  scheduledDate        DateTime  @map("scheduled_date") @db.Date
  scheduledAmount      Decimal   @map("scheduled_amount") @db.Decimal(15, 2)
  paidDate             String?   @map("paid_date") @db.VarChar(8)
  paidAmount           Decimal?  @map("paid_amount") @db.Decimal(15, 2)
  transactionId        String?   @map("transaction_id") @db.Uuid
  savingsPaymentStatus String    @default("SCHEDULED") @map("savings_payment_status") @db.VarChar(20)
  createdBy            String?   @map("created_by") @db.Uuid
  updatedBy            String?   @map("updated_by") @db.Uuid
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

