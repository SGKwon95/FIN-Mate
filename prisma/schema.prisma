model LoanApplication {
  applicationId         String    @id @default(dbgenerated("gen_random_uuid()")) @map("application_id") @db.Uuid
  partyId               String    @map("party_id") @db.Uuid
  productId             String    @map("product_id") @db.Uuid
  requestedAmount       Decimal   @map("requested_amount") @db.Decimal(15, 2)
  requestedPeriodMonths Int?      @map("requested_period_months")
  loanPurpose           String?   @map("loan_purpose") @db.VarChar(100)
  applicationStatus     String    @default("DRAFT") @map("application_status") @db.VarChar(20)
  approvedAmount        Decimal?  @map("approved_amount") @db.Decimal(15, 2)
  approvedRate          Decimal?  @map("approved_rate") @db.Decimal(7, 4)
  rejectionReason       String?   @map("rejection_reason") @db.VarChar(500)
  contractId            String?   @map("contract_id") @db.Uuid
  channel               String?   @db.VarChar(20)
  branchId              String?   @map("branch_id") @db.Uuid
  employeeId            String?   @map("employee_id") @db.Uuid
  submittedAt           DateTime? @map("submitted_at") @db.Timestamptz()
  decidedAt             DateTime? @map("decided_at") @db.Timestamptz()
  createdBy             String?   @map("created_by") @db.Uuid
  updatedBy             String?   @map("updated_by") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  party         Party             @relation(fields: [partyId], references: [partyId])
  product       Product           @relation(fields: [productId], references: [productId])
  contract      Contract?         @relation(fields: [contractId], references: [contractId])
  branch        Branch?           @relation(fields: [branchId], references: [branchId])
  employee      Employee?         @relation(fields: [employeeId], references: [employeeId])
  approvalSteps LoanApprovalStep[]
  documents     LoanDocument[]
  collaterals   LoanCollateral[]

  @@index([partyId], map: "idx_loan_application_party")
  @@index([productId], map: "idx_loan_application_product")
  @@index([applicationStatus], map: "idx_loan_application_status")
  @@map("loan_application")
}

model LoanApprovalStep {
  stepId        String    @id @default(dbgenerated("gen_random_uuid()")) @map("step_id") @db.Uuid
