generator client {
  provider = "prisma-client-js"
}

// Prisma 7: url은 prisma.config.ts의 migrate.url로 이동, 클라이언트는 adapter로 연결
datasource db {
  provider = "postgresql"
}

// ============================================================
// 1. 공통 코드
// ============================================================
model CommonCodeGroup {
  groupId     String       @id @map("group_id") @db.VarChar(50)
  groupName   String       @map("group_name") @db.VarChar(100)
  description String?      @db.Text
  useYn       String       @default("Y") @map("use_yn") @db.Char(1)
  createdBy   String?      @map("created_by") @db.Uuid
  updatedBy   String?      @map("updated_by") @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  commonCodes CommonCode[]

  @@map("common_code_group")
}

model CommonCode {
  codeId    BigInt   @id @default(autoincrement()) @map("code_id")
  groupId   String   @map("group_id") @db.VarChar(50)
  code      String   @db.VarChar(50)
  codeName  String   @map("code_name") @db.VarChar(100)
  codeValue String?  @map("code_value") @db.VarChar(100)
  sortOrder Int      @default(0) @map("sort_order")
  useYn     String   @default("Y") @map("use_yn") @db.Char(1)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  group CommonCodeGroup @relation(fields: [groupId], references: [groupId])

  @@unique([groupId, code], map: "uq_common_code")
  @@map("common_code")
}

// ============================================================
// 2. 고객 마스터 (Party)
// ============================================================
model Party {
  partyId              String    @id @default(dbgenerated("gen_random_uuid()")) @map("party_id") @db.Uuid
  partyNo              String?   @unique @map("party_no") @db.VarChar(30)  // 화면 표시용 고객번호 (예: IND-2026-0001)
  partyName            String    @map("party_name") @db.VarChar(100)
  partyRole            String    @map("party_role") @db.VarChar(20)  // INDIVIDUAL | CORPORATE
  partyStatus          String    @default("ACTIVE") @map("party_status") @db.VarChar(20)
  partyStatusReason    String?   @map("party_status_reason") @db.VarChar(200)
  partyStatusChangedAt DateTime? @map("party_status_changed_at") @db.Timestamptz()
  createdBy            String?   @map("created_by") @db.Uuid
  updatedBy            String?   @map("updated_by") @db.Uuid
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  individual                 Individual?
  corporate                  Corporate?
  partyAuth                  PartyAuth?
  employee                   Employee?
  accounts                   Account[]
  contracts                  Contract[]
  loanApplications           LoanApplication[]
  counterpartyTxns           Transaction[]            @relation("CounterpartyPartyTxns")
  notifications              Notification[]
  submittedInstructions      TransferInstruction[]    @relation("InstructionSubmittedBy")
  approvedInstructions       TransferInstruction[]    @relation("InstructionApprovedBy")
  uploadedDocuments          Document[]               @relation("DocumentUploadedBy")
  submittedDocuments         Document[]               @relation("DocumentSubmittedBy")
  scheduledTransfers         ScheduledTransfer[]

  @@map("party")
}

// ============================================================
// 2-1. 개인 고객 상세
// ============================================================
model Individual {
  individualId                String    @id @default(dbgenerated("gen_random_uuid()")) @map("individual_id") @db.Uuid
  partyId                     String    @unique @map("party_id") @db.Uuid
  individualPhone             String?   @map("individual_phone") @db.VarChar(20)
  individualEmail             String?   @map("individual_email") @db.VarChar(200)
  individualCi                String    @map("indivisual_ci") @db.VarChar(50)  // 원본 오타 유지
  transferLimitPerTransaction Decimal?  @map("transfer_limit_per_transaction") @db.Decimal(15, 2)
  transferLimitPerDay         Decimal?  @map("transfer_limit_per_day") @db.Decimal(15, 2)
  zipCode                     String?   @map("zip_code") @db.VarChar(5)
  address                     String?   @db.VarChar(200)
  addressDetail               String?   @map("address_detail") @db.VarChar(100)
  employmentType              String?   @map("employment_type") @db.VarChar(20)
  employerName                String?   @map("employer_name") @db.VarChar(100)
  jobTitle                    String?   @map("job_title") @db.VarChar(50)
  industryCode                String?   @map("industry_code") @db.VarChar(10)
  employmentStartDate         String?   @map("employment_start_date") @db.VarChar(8)
  annualIncome                Decimal?  @map("annual_income") @db.Decimal(15, 2)
  individualStatus            String    @default("ACTIVE") @map("individual_status") @db.VarChar(20)
  // 기업뱅킹 소속 (법인 소속 시만 사용)
  corpId                      String?   @map("corp_id") @db.Uuid
  corpDepartment              String?   @map("corp_department") @db.VarChar(100)
  corpPosition                String?   @map("corp_position") @db.VarChar(100)
  corpRole                    String?   @map("corp_role") @db.VarChar(30)
  corpStatus                  String?   @map("corp_status") @db.VarChar(20)
  corpFailedAttemptCount      Int?      @map("corp_failed_attempt_count")
  corpLockedAt                DateTime? @map("corp_locked_at") @db.Timestamptz()
  corpLastLoginAt             DateTime? @map("corp_last_login_at") @db.Timestamptz()
  createdBy                   String?   @map("created_by") @db.Uuid
  updatedBy                   String?   @map("updated_by") @db.Uuid
  createdAt                   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  party     Party      @relation(fields: [partyId], references: [partyId])
  corporate Corporate? @relation(fields: [corpId], references: [corporateId])

  @@index([individualCi], map: "idx_individual_ci")
  @@index([corpId], map: "idx_individual_corp")
  @@map("individual")
}

// ============================================================
// 2-2. 법인 고객 상세
// ============================================================
model Corporate {
  corporateId               String    @id @default(dbgenerated("gen_random_uuid()")) @map("corporate_id") @db.Uuid
  partyId                   String    @unique @map("party_id") @db.Uuid
  businessRegNo             String    @map("business_reg_no") @db.VarChar(20)
  corporationRegNo          String?   @map("corporation_reg_no") @db.VarChar(20)
  companyType               String?   @map("company_type") @db.VarChar(20)
  industryCode              String?   @map("industry_code") @db.VarChar(10)
  businessTypeCode          String?   @map("business_type_code") @db.VarChar(10)
  establishedDate           String?   @map("established_date") @db.VarChar(8)
  fiscalYearEndMonth        Int?      @map("fiscal_year_end_month") @db.SmallInt
  representativeName        String?   @map("representative_name") @db.VarChar(100)
  representativePhone       String?   @map("representative_phone") @db.VarChar(20)
  representativeEmail       String?   @map("representative_email") @db.VarChar(100)
  representativeNationality String?   @map("representative_nationality") @db.VarChar(3)
  capitalAmount             Decimal?  @map("capital_amount") @db.Decimal(15, 2)
  bizZipCode                String?   @map("biz_zip_code") @db.VarChar(5)
  bizAddress                String?   @map("biz_address") @db.VarChar(200)
  bizAddressDetail          String?   @map("biz_address_detail") @db.VarChar(100)
  regZipCode                String?   @map("reg_zip_code") @db.VarChar(5)
  regAddress                String?   @map("reg_address") @db.VarChar(200)
  regAddressDetail          String?   @map("reg_address_detail") @db.VarChar(100)
  creditGrade               String?   @map("credit_grade") @db.VarChar(10)
  creditRatingAgency        String?   @map("credit_rating_agency") @db.VarChar(50)
  creditRatedAt             String?   @map("credit_rated_at") @db.VarChar(8)
  beneficialOwnerVerified   Boolean   @default(false) @map("beneficial_owner_verified")
  beneficialOwnerVerifiedAt DateTime? @map("beneficial_owner_verified_at") @db.Timestamptz()
  createdBy                 String?   @map("created_by") @db.Uuid
  updatedBy                 String?   @map("updated_by") @db.Uuid
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                 DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  party       Party        @relation(fields: [partyId], references: [partyId])
  individuals Individual[]

  @@map("corporate")
}

// ============================================================
// 2-3. 로그인 인증 정보
// ============================================================
model PartyAuth {
  authId             String    @id @default(dbgenerated("gen_random_uuid()")) @map("auth_id") @db.Uuid
  partyId            String    @unique @map("party_id") @db.Uuid
  loginId            String    @unique @map("login_id") @db.VarChar(100)
  passwordHash       String    @map("password_hash") @db.VarChar(255)
  passwordSalt       String?   @map("password_salt") @db.VarChar(255)
  passwordChangedAt  DateTime  @default(now()) @map("password_changed_at") @db.Timestamptz()
  passwordExpiresAt  DateTime? @map("password_expires_at") @db.Timestamptz()
  partyAuthStatus    String    @default("ACTIVE") @map("party_auth_status") @db.VarChar(20)
  failedAttemptCount Int       @default(0) @map("failed_attempt_count")
  lockedAt           DateTime? @map("locked_at") @db.Timestamptz()
  lastLoginAt        DateTime? @map("last_login_at") @db.Timestamptz()
  sessionToken       String?   @unique @map("session_token") @db.VarChar(36)
  createdBy          String?   @map("created_by") @db.Uuid
  updatedBy          String?   @map("updated_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  party Party @relation(fields: [partyId], references: [partyId])

  @@index([loginId], map: "idx_party_auth_login_id")
  @@map("party_auth")
}

// ============================================================
// 23. 지점
// ============================================================
model Branch {
  branchId            String    @id @default(dbgenerated("gen_random_uuid()")) @map("branch_id") @db.Uuid
  branchCode          String    @unique @map("branch_code") @db.VarChar(10)
  branchName          String    @map("branch_name") @db.VarChar(100)
  branchType          String    @map("branch_type") @db.VarChar(20)
  branchStatus        String    @default("ACTIVE") @map("branch_status") @db.VarChar(20)
  branchZipCode       String?   @map("branch_zip_code") @db.VarChar(5)
  branchAddress       String?   @map("branch_address") @db.VarChar(200)
  branchAddressDetail String?   @map("branch_address_detail") @db.VarChar(100)
  branchPhone         String?   @map("branch_phone") @db.VarChar(20)
  branchFax           String?   @map("branch_fax") @db.VarChar(20)
  openTime            DateTime? @map("open_time") @db.Time()
  closeTime           DateTime? @map("close_time") @db.Time()
  openedDate          String?   @map("opened_date") @db.VarChar(8)
  closedDate          String?   @map("closed_date") @db.VarChar(8)
  createdBy           String?   @map("created_by") @db.Uuid
  updatedBy           String?   @map("updated_by") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  employees        Employee[]
  contracts        Contract[]
  loanApplications LoanApplication[]

  @@index([branchStatus], map: "idx_branch_status")
  @@index([branchType], map: "idx_branch_type")
  @@map("branch")
}

// ============================================================
// 24. 은행 직원
// ============================================================
model Employee {
  employeeId     String    @id @default(dbgenerated("gen_random_uuid()")) @map("employee_id") @db.Uuid
  branchId       String    @map("branch_id") @db.Uuid
  partyId        String?   @unique @map("party_id") @db.Uuid
  employeeNo     String    @unique @map("employee_no") @db.VarChar(20)
  employeeName   String    @map("employee_name") @db.VarChar(100)
  department     String?   @db.VarChar(100)
  position       String?   @db.VarChar(50)
  employeeEmail  String?   @map("employee_email") @db.VarChar(200)
  employeePhone  String?   @map("employee_phone") @db.VarChar(20)
  employeeStatus String    @default("ACTIVE") @map("employee_status") @db.VarChar(20)
  hiredDate      DateTime  @map("hired_date") @db.Date
  resignedDate   String?   @map("resigned_date") @db.VarChar(8)
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  branch            Branch             @relation(fields: [branchId], references: [branchId])
  party             Party?             @relation(fields: [partyId], references: [partyId])
  productTerms      ProductTerms[]
  contracts         Contract[]
  loanApplications   LoanApplication[]
  approvedApplications LoanApplication[] @relation("ApprovalAuthority")
  loanApprovalSteps  LoanApprovalStep[]
  approvedTxns       Transaction[]
  verifiedDocuments  Document[]

  @@index([branchId], map: "idx_employee_branch")
  @@index([employeeNo], map: "idx_employee_no")
  @@map("employee")
}

// ============================================================
// 3. 상품 마스터
// ============================================================
model Product {
  productId             String   @id @default(dbgenerated("gen_random_uuid()")) @map("product_id") @db.Uuid
  productName           String   @map("product_name") @db.VarChar(200)
  // SQL 원본의 REFERENCES common_code(type_code)는 존재하지 않는 컬럼 참조 (버그).
  // PROD_TYPE 그룹의 code 값(DEPOSIT|LOAN)을 직접 저장하는 방식으로 수정.
  productTypeCode       String   @map("product_type_code") @db.VarChar(20)
  productStatus         String   @default("ACTIVE") @map("product_status") @db.VarChar(20)
  launchDate            DateTime @map("launch_date") @db.Date
  expiryDate            String?  @map("expiry_date") @db.VarChar(8)
  periodType            String   @default("UNLIMITED") @map("period_type") @db.VarChar(20)
  contractPeriodMonths  Int?     @map("contract_period_months")
  salesTarget           String   @default("ALL") @map("sales_target") @db.VarChar(20)
  isDepositInsured      Boolean  @default(false) @map("is_deposit_insured")
  depositInsuranceLimit Decimal? @map("deposit_insurance_limit") @db.Decimal(15, 2)
  description           String?  @db.Text  // CSV 임포트용 추가 필드
  createdBy             String   @map("created_by") @db.Uuid
  updatedBy             String   @map("updated_by") @db.Uuid
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  depositDetail       DepositDetail?
  loanDetail          LoanDetail?
  productTerms        ProductTerms[]
  productRates        ProductRate[]
  productRateTiers    ProductRateTier[]
  productRateBenefits ProductRateBenefit[]
  productFees         ProductFee[]
  contracts           Contract[]
  loanApplications    LoanApplication[]

  @@index([productTypeCode], map: "idx_product_type")
  @@index([productStatus], map: "idx_product_status")
  @@map("product")
}

// ============================================================
// 4. 약관 버전 관리
// ============================================================
model ProductTerms {
  termsId               String    @id @default(dbgenerated("gen_random_uuid()")) @map("terms_id") @db.Uuid
  productId             String    @map("product_id") @db.Uuid
  termsType             String    @map("terms_type") @db.VarChar(30)
  version               String    @db.VarChar(20)
  effectiveDate         String    @map("effective_date") @db.VarChar(8)
  expiryDate            String?   @map("expiry_date") @db.VarChar(8)
  changedAt             DateTime? @map("changed_at") @db.Timestamptz()
  contentUrl            String?   @map("content_url") @db.Text
  changeReason          String?   @map("change_reason") @db.Text
  responsibleDepartment String?   @map("responsible_department") @db.VarChar(100)
  responsibleEmployeeId String?   @map("responsible_employee_id") @db.Uuid
  createdBy             String?   @map("created_by") @db.Uuid
  updatedBy             String?   @map("updated_by") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  product             Product                  @relation(fields: [productId], references: [productId])
  responsibleEmployee Employee?                @relation(fields: [responsibleEmployeeId], references: [employeeId])
  contractAgreements  ContractTermsAgreement[]

  @@unique([productId, termsType, version])
  @@map("product_terms")
}

// ============================================================
// 5. 금리 관리
// ============================================================
model ProductRate {
  productRateId String   @id @default(dbgenerated("gen_random_uuid()")) @map("product_rate_id") @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  rateType      String   @map("rate_type") @db.VarChar(20)     // BASE | SPREAD
  rateStructure String   @default("FIXED") @map("rate_structure") @db.VarChar(20)
  rate          Decimal  @db.Decimal(7, 4)
  effectiveFrom DateTime @map("effective_from") @db.Date
  effectiveTo   String?  @map("effective_to") @db.VarChar(8)
  createdBy     String   @map("created_by") @db.Uuid
  updatedBy     String?  @map("updated_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  product Product @relation(fields: [productId], references: [productId])

  @@index([productId], map: "idx_product_rate_product")
  @@map("product_rate")
}

model ProductRateTier {
  rateTierId    String   @id @default(dbgenerated("gen_random_uuid()")) @map("rate_tier_id") @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  tierType      String   @map("tier_type") @db.VarChar(20)     // AMOUNT | PERIOD
  minValue      Decimal? @map("min_value") @db.Decimal(15, 2)
  maxValue      Decimal? @map("max_value") @db.Decimal(15, 2)
  rate          Decimal  @db.Decimal(7, 4)
  effectiveFrom DateTime @map("effective_from") @db.Date
  effectiveTo   String?  @map("effective_to") @db.VarChar(8)
  createdBy     String?  @map("created_by") @db.Uuid
  updatedBy     String?  @map("updated_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  product Product @relation(fields: [productId], references: [productId])

  @@index([productId], map: "idx_product_rate_tier_product")
  @@map("product_rate_tier")
}

model ProductRateBenefit {
  rateBenefitId        String   @id @default(dbgenerated("gen_random_uuid()")) @map("rate_benefit_id") @db.Uuid
  productId            String   @map("product_id") @db.Uuid
  benefitName          String   @map("benefit_name") @db.VarChar(100)
  benefitRate          Decimal  @map("benefit_rate") @db.Decimal(7, 4)
  conditionDescription String?  @map("condition_description") @db.Text
  effectiveFrom        DateTime @map("effective_from") @db.Date
  effectiveTo          String?  @map("effective_to") @db.VarChar(8)
  createdBy            String?  @map("created_by") @db.Uuid
  updatedBy            String?  @map("updated_by") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  product          Product               @relation(fields: [productId], references: [productId])
  contractBenefits ContractRateBenefit[]

  @@index([productId], map: "idx_product_rate_benefit_product")
  @@map("product_rate_benefit")
}

// ============================================================
// 5-4. 수수료 정책
// ============================================================
model ProductFee {
  feeId           String   @id @default(dbgenerated("gen_random_uuid()")) @map("fee_id") @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  feeType         String   @map("fee_type") @db.VarChar(30)
  channel         String   @default("ALL") @db.VarChar(20)
  minAmount       Decimal? @map("min_amount") @db.Decimal(15, 2)
  maxAmount       Decimal? @map("max_amount") @db.Decimal(15, 2)
  feeAmount       Decimal? @map("fee_amount") @db.Decimal(15, 2)
  feeRate         Decimal? @map("fee_rate") @db.Decimal(7, 4)
  waiverCondition String?  @map("waiver_condition") @db.Text
  effectiveFrom   String   @map("effective_from") @db.VarChar(8)
  effectiveTo     String?  @map("effective_to") @db.VarChar(8)
  createdBy       String?  @map("created_by") @db.Uuid
  updatedBy       String?  @map("updated_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  product Product @relation(fields: [productId], references: [productId])

  @@index([productId], map: "idx_product_fee_product")
  @@map("product_fee")
}

// ============================================================
// 6. 예금 상세
// ============================================================
model DepositDetail {
  depositDetailId            String   @id @default(dbgenerated("gen_random_uuid()")) @map("deposit_detail_id") @db.Uuid
  productId                  String   @unique @map("product_id") @db.Uuid
  interestType               String   @map("interest_type") @db.VarChar(10)    // SIMPLE | COMPOUND
  rateType                   String   @map("rate_type") @db.VarChar(10)         // FIXED | VARIABLE
  transactionType            String   @map("transaction_type") @db.VarChar(20)  // TIME_DEPOSIT | SAVINGS | DEMAND
  minAmount                  Decimal? @map("min_amount") @db.Decimal(15, 2)
  maxAmount                  Decimal? @map("max_amount") @db.Decimal(15, 2)
  minPeriodMonths            Int?     @map("min_period_months")
  maxPeriodMonths            Int?     @map("max_period_months")
  earlyWithdrawalPenaltyRate Decimal? @map("early_withdrawal_penalty_rate") @db.Decimal(7, 4)
  prepaymentAllowed          Boolean  @default(false) @map("prepayment_allowed")  // 선납 가능 여부 (SAVINGS 전용)
  deferralAllowed            Boolean  @default(false) @map("deferral_allowed")    // 이연 가능 여부 (SAVINGS 전용)
  createdBy                  String?  @map("created_by") @db.Uuid
  updatedBy                  String?  @map("updated_by") @db.Uuid
  createdAt                  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  product Product @relation(fields: [productId], references: [productId])

  @@map("deposit_detail")
}

// ============================================================
// 7. 대출 상세
// ============================================================
model LoanDetail {
  loanDetailId            String   @id @default(dbgenerated("gen_random_uuid()")) @map("loan_detail_id") @db.Uuid
  productId               String   @unique @map("product_id") @db.Uuid
  loanType                String   @default("CREDIT") @map("loan_type") @db.VarChar(20)
  // MORTGAGE(담보대출) | JEONSE(전세자금) | CREDIT(신용대출) | OVERDRAFT(마이너스통장)
  baseRateType            String   @map("base_rate_type") @db.VarChar(20)
  interestType            String   @map("interest_type") @db.VarChar(10)
  maxLtvRatio             Decimal? @map("max_ltv_ratio") @db.Decimal(5, 4)
  maxDtiRatio             Decimal? @map("max_dti_ratio") @db.Decimal(5, 4)
  collateralRequired      Boolean  @default(false) @map("collateral_required")
  collateralType          String?  @map("collateral_type") @db.VarChar(30)
