// SBank Database Schema
// Generated: 2026-05-11
// DBMS: PostgreSQL 14+

// ============================================================
// 공통 코드 도메인
// ============================================================

Table common_code_group {
  그룹ID      varchar(50)  [pk]
  그룹명      varchar(100) [not null]
  설명        text
  사용여부    char(1)      [not null, default: 'Y']
  생성자ID    uuid
  수정자ID    uuid
  생성일시    timestamp    [not null, default: `CURRENT_TIMESTAMP`]
  수정일시    timestamp    [not null, default: `CURRENT_TIMESTAMP`]
}

Table common_code {
  코드ID      bigserial    [pk]
  그룹ID      varchar(50)  [not null, ref: > common_code_group.그룹ID]
  코드        varchar(50)  [not null]
  코드명      varchar(100) [not null]
  코드값      varchar(100)
  정렬순서    int          [not null, default: 0]
  사용여부    char(1)      [not null, default: 'Y']
  생성자ID    uuid
  수정자ID    uuid
  생성일시    timestamp    [not null, default: `CURRENT_TIMESTAMP`]
  수정일시    timestamp    [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    (그룹ID, 코드) [unique]
    그룹ID
  }
}


// ============================================================
// 고객 도메인 (Supertype / Subtype)
// ============================================================

Table party {
  당사자ID              uuid         [pk, default: `gen_random_uuid()`]
  당사자명              varchar(100) [not null]
  당사자개인법인구분    varchar(20)  [not null, note: 'INDIVIDUAL / CORPORATE']
  당사자상태            varchar(20)  [not null, default: 'ACTIVE', note: 'ACTIVE / SUSPENDED / DORMANT / WITHDRAWN']
  당사자상태사유        varchar(200)
  당사자상태변경일시    timestamptz

  생성자ID              uuid
  수정자ID              uuid
  생성일시              timestamptz  [not null, default: `now()`]
  수정일시              timestamptz  [not null, default: `now()`]
}

Table individual {
  개인고객ID               uuid         [pk, default: `gen_random_uuid()`]
  당사자ID                 uuid         [not null, unique, ref: - party.당사자ID]
  개인고객전화번호         varchar(20)  [note: '휴대폰 번호 (예: 010-1234-5678)']
  개인고객이메일           varchar(200)
  개인고객CI               varchar(50)      [not null]
  성별                     char(1)          [not null]

  건별이체한도            decimal(15,2)
  일일이체한도            decimal(15,2)

  우편번호                varchar(5)
  주소                    varchar(200)
  상세주소                varchar(100)

  고용형태                varchar(20)  [note: 'EMPLOYED / SELF_EMPLOYED / CONTRACT / UNEMPLOYED / RETIRED']
  직장명                  varchar(100)
  직위                    varchar(50)
  업종코드                varchar(10)
  입사일                  date
  연소득                  decimal(15,2)

  개인고객상태            varchar(20)  [not null, default: 'ACTIVE', note: 'ACTIVE / SUSPENDED / DORMANT / WITHDRAWN']

  생성자ID                uuid
  수정자ID                uuid
  생성일시                timestamptz  [not null, default: `now()`]
  수정일시                timestamptz  [not null, default: `now()`]

  indexes {
    개인고객CI
  }
}

Table corporate {
  법인ID                  uuid         [pk, default: `gen_random_uuid()`]
  당사자ID                uuid         [not null, unique, ref: - party.당사자ID]

  // 기업 식별
  사업자등록번호          varchar(20)  [not null, note: '사업자등록번호']
  법인등록번호            varchar(20)  [note: '법인등록번호']

  // 기업 기본 정보
  기업유형                varchar(20)  [note: 'STOCK / LIMITED / COOPERATIVE / PUBLIC / OTHER']
  업종코드                varchar(10)
  설립일                  date
  결산월                  smallint     [note: '1–12']
  대표자명                varchar(100)
  자본금                  decimal(15,2)

  // 사업장 주소
  사업장우편번호          varchar(5)
  사업장주소              varchar(200)
  사업장상세주소          varchar(100)

  // 등기주소 (법인등기부등본 기준 — 사업장 주소와 다를 경우 입력)
  등기우편번호            varchar(5)
  등기주소                varchar(200)
  등기상세주소            varchar(100)

  // 신용등급
  신용등급                varchar(10)  [note: 'AAA ~ D']
  신용평가사              varchar(50)  [note: 'NICE / KCB / KIS / SCI 등']
  신용평가일              date

  // 실소유자 확인 (AML)
  실소유자확인여부        boolean      [not null, default: false]
  실소유자확인일시        timestamptz

  생성자ID                uuid
  수정자ID                uuid
  생성일시                timestamptz  [not null, default: `now()`]
  수정일시                timestamptz  [not null, default: `now()`]
}

Table party_auth {
  인증ID                  uuid         [pk, default: `gen_random_uuid()`]
  당사자ID                uuid         [not null, unique, ref: - party.당사자ID]

  로그인ID                varchar(100) [not null, unique]
  비밀번호해시            varchar(255) [not null, note: 'bcrypt / argon2 해시']
  비밀번호솔트            varchar(255)

  비밀번호변경일시        timestamptz  [not null, default: `now()`]
  비밀번호만료일시        timestamptz

  상태                    varchar(20)  [not null, default: 'ACTIVE', note: 'ACTIVE / LOCKED / DISABLED']
  로그인실패횟수          int          [not null, default: 0]
  잠금일시                timestamptz

  최종로그인일시          timestamptz

  생성자ID                uuid
  수정자ID                uuid
  생성일시                timestamptz  [not null, default: `now()`]
  수정일시                timestamptz  [not null, default: `now()`]

  indexes {
    로그인ID
  }
}


// ============================================================
// 상품 도메인
// ============================================================

Table product {
  상품ID                           uuid         [pk, default: `gen_random_uuid()`]
  상품명                           varchar(200) [not null]
  상품유형코드                     varchar(20)  [not null, note: 'common_code 참조 (그룹ID: PROD_TYPE) — DEPOSIT / LOAN']
  상태                             varchar(20)  [not null, default: 'ACTIVE', note: 'ACTIVE / INACTIVE / SUSPENDED']
  출시일                           varchar(10)  [not null]
  만료일                           date

  기간유형            varchar(20)   [not null, default: 'UNLIMITED', note: 'UNLIMITED=제한없음 / FIXED=고정 / FLEXIBLE=선택']
  계약기간_개월       integer       [note: 'FIXED=상품 고정 기간, FLEXIBLE=기본값 (개월)']

  판매대상            varchar(20)   [not null, default: 'ALL', note: 'ALL / INDIVIDUAL / CORPORATE']

  예금자보호여부      boolean      [not null, default: false, note: '예금보험공사 보호 여부']
  예금자보호한도      decimal(15,2) [note: '통상 50,000,000 (1인당 5천만원)']

  생성자ID    uuid        [not null]
  수정자ID    uuid        [not null]
  생성일시    timestamptz [not null, default: `now()`]
  수정일시    timestamptz [not null, default: `now()`]

  indexes {
    상품유형코드
    상태
  }
}

Table product_terms {
  약관ID       uuid        [pk, default: `gen_random_uuid()`]
  상품ID       uuid        [not null, ref: > product.상품ID]

  // TYPE_SPECIFIC(상품별 약관)
  약관유형     varchar(30) [not null, note: 'BASIC / TYPE_SPECIFIC']
  버전         varchar(20) [not null]
  시행일       varchar(10) [not null]
  종료일       varchar(10) [note: 'NULL=현재 유효']
  변경일시     timestamptz
  내용URL      text
  변경사유     text        [note: '버전 변경 사유 (예: 법령 개정, 약관 개선 등)']

  담당부서     varchar(100)
  담당직원ID   uuid        [ref: > employee.직원ID]

  생성자ID     uuid
  수정자ID     uuid
  생성일시     timestamptz [not null, default: `now()`]
  수정일시     timestamptz [not null, default: `now()`]

  indexes {
    (상품ID, 약관유형, 버전) [unique]
  }
}

Table product_rate {
  상품금리ID   uuid         [pk, default: `gen_random_uuid()`]
  상품ID       uuid         [not null, ref: > product.상품ID]

  금리유형     varchar(20)  [not null, note: 'BASE / SPREAD']
  금리구조     varchar(20)  [not null, default: 'FIXED', note: 'FIXED=고정 / VARIABLE=변동 / CONFIRMED=확정']
  금리         decimal(7,4) [not null]
  적용시작일   varchar(10)  [not null]
  적용종료일   varchar(10)  [note: 'NULL=현재 적용 중']

  생성자ID     uuid         [not null]
  수정자ID     uuid
  생성일시     timestamptz  [not null, default: `now()`]
  수정일시     timestamptz  [not null, default: `now()`]

  indexes {
    상품ID
  }
}

Table product_rate_tier {
  금리구간ID   uuid          [pk, default: `gen_random_uuid()`]
  상품ID       uuid          [not null, ref: > product.상품ID]

  구간유형     varchar(20)   [not null, note: 'AMOUNT / PERIOD']
  최솟값       decimal(15,2) [note: '구간 하한 (NULL=하한 없음)']
  최댓값       decimal(15,2) [note: '구간 상한 (NULL=상한 없음)']
  금리         decimal(7,4)  [not null]

  적용시작일   varchar(10)   [not null]
  적용종료일   varchar(10)   [note: 'NULL=현재 적용 중']

  생성자ID     uuid
  수정자ID     uuid
  생성일시     timestamptz   [not null, default: `now()`]
  수정일시     timestamptz   [not null, default: `now()`]

  indexes {
    상품ID
  }
}

Table product_rate_benefit {
  우대금리ID    uuid         [pk, default: `gen_random_uuid()`]
  상품ID        uuid         [not null, ref: > product.상품ID]

  우대조건명    varchar(100) [not null, note: '우대 조건명 (예: 급여이체 고객)']
  우대금리      decimal(7,4) [not null, note: '우대 금리 (예: 0.002 = +0.2%)']
  조건설명      text         [note: '조건 상세']

  적용시작일    varchar(10)  [not null]
  적용종료일    varchar(10)  [note: 'NULL=현재 적용 중']

  생성자ID      uuid
  수정자ID      uuid
  생성일시      timestamptz  [not null, default: `now()`]
  수정일시      timestamptz  [not null, default: `now()`]

  indexes {
    상품ID
  }
}

Table product_fee {
  수수료ID      uuid         [pk, default: `gen_random_uuid()`]
  상품ID        uuid         [not null, ref: > product.상품ID]

  수수료유형    varchar(30)  [not null, note: 'TRANSFER=이체 / WITHDRAWAL=출금 / DEPOSIT=입금 / EARLY_REPAYMENT=중도상환 / OTHER=기타']
  채널          varchar(20)  [not null, default: 'ALL', note: 'ALL / APP / ATM / TELLER / INTERNET']

  구간하한      decimal(15,2) [note: 'NULL=하한 없음']
  구간상한      decimal(15,2) [note: 'NULL=상한 없음']

  고정수수료    decimal(15,2) [note: '원 단위 고정 수수료']
  비율수수료    decimal(7,4)  [note: '예: 0.001 = 0.1%']
  면제조건      text          [note: '예: 급여계좌, VIP 등']

  적용시작일    varchar(10)  [not null]
  적용종료일    varchar(10)  [note: 'NULL=현재 적용 중']

  생성자ID      uuid
  수정자ID      uuid
  생성일시      timestamptz  [not null, default: `now()`]
  수정일시      timestamptz  [not null, default: `now()`]

  indexes {
    상품ID
  }
}

Table deposit_detail {
  예금상세ID            uuid         [pk, default: `gen_random_uuid()`]
  상품ID                uuid         [not null, unique, ref: - product.상품ID]

  이자유형              varchar(10)  [not null, note: 'SIMPLE / COMPOUND']
  금리유형              varchar(10)  [not null, note: 'FIXED / VARIABLE']
  거래유형              varchar(20)  [not null, note: 'TIME_DEPOSIT / SAVINGS / DEMAND']

  최소금액              decimal(15,2)
  최대금액              decimal(15,2)
  최소기간월수          int
  최대기간월수          int
  중도해지위약금율      decimal(7,4)

  생성자ID              uuid
  수정자ID              uuid
  생성일시              timestamptz  [not null, default: `now()`]
  수정일시              timestamptz  [not null, default: `now()`]
}

Table loan_detail {
  대출상세ID          uuid         [pk, default: `gen_random_uuid()`]
  상품ID              uuid         [not null, unique, ref: - product.상품ID]

  기준금리유형        varchar(20)  [not null, note: 'COFIX / CD91 / BASE_RATE / PRIME (실제 금리 값은 product_rate 참조)']
  이자유형            varchar(10)  [not null, note: 'SIMPLE=단리 / COMPOUND=복리']

  최대LTV비율         decimal(5,4)
  최대DTI비율         decimal(5,4)

  담보필요여부        boolean      [not null, default: false]
  담보유형            varchar(30)  [note: 'REAL_ESTATE / DEPOSIT / SECURITIES / NONE']
  질권설정가능여부    boolean      [not null, default: false]

  최소대출금액        decimal(15,2)
  최대대출금액        decimal(15,2)
  최대대출기간월수    int

  상환방식            varchar(25)  [not null, note: 'BULLET / EQUAL_PRINCIPAL / EQUAL_INSTALLMENT / FLEXIBLE']

  중도상환가능여부    boolean      [not null, default: false]
  중도상환수수료율    decimal(7,4) [note: '예: 0.014 = 1.4%']

  지연이자율          decimal(7,4) [note: '연체 시 적용. 예: 0.15 = 15%']

  생성자ID            uuid
  수정자ID            uuid
  생성일시            timestamptz  [not null, default: `now()`]
  수정일시            timestamptz  [not null, default: `now()`]
}

/*
BULLET	만기일시상환	매달 이자만 내다가 만기에 원금 전액 상환
EQUAL_PRINCIPAL	원금균등상환	매달 원금을 동일하게 나눠 상환, 이자는 줄어듦
EQUAL_INSTALLMENT	원리금균등상환	매달 납입액(원금+이자) 동일, 가장 일반적인 방식
FLEXIBLE	자유상환	납입 일정·금액을 자유롭게 선택
*/




// ============================================================
// 계약·계좌 도메인
// ============================================================

Table contract {
  계약ID                          uuid         [pk, default: `gen_random_uuid()`]
  당사자ID                        uuid         [not null, ref: > party.당사자ID]
  상품ID                          uuid         [not null, ref: > product.상품ID]
  계약일                          varchar(10)  [not null]
  실행일자                        varchar(10)  [note: '대출 실행일·예금 개시일. NULL=즉시 실행']
  만기일                          varchar(10)  [note: '계약일 + 기간을 스냅샷으로 저장']
  종료일자                        varchar(10)  [note: '실제 종료일. 중도해지 시 만기일과 다름']
  계약기간_개월                   smallint     [note: '계약기간(개월). 수시입출금 등 기간 없는 상품은 NULL']
  계약금액                        decimal(15,2)
  인지세                          decimal(15,2) [note: '대출 계약 시 납부. 대출금액 구간별 차등']
  계약상태                        varchar(25)  [not null, default: 'ACTIVE', note: 'ACTIVE / CLOSED / WITHDRAWN / ILLEGALLY_TERMINATED']
  최종적용금리                    decimal(7,4) [not null, note: '계약 시점 확정 금리 (기준+가산-우대). product_rate 변동과 무관하게 보존']

  지점ID                          uuid         [ref: > branch.지점ID, note: 'NULL=비대면(앱·인터넷)']
  담당직원ID                      uuid         [ref: > employee.직원ID]
  담당직원명                      varchar(100) [note: '스냅샷']
  계약서파일URL                   text

  생성자ID    uuid
  수정자ID    uuid
  생성일시    timestamptz [not null, default: `now()`]
  수정일시    timestamptz [not null, default: `now()`]

  indexes {
    당사자ID
    상품ID
    계약상태
    지점ID
  }
}

Table contract_terms_agreement {
  계약ID      uuid        [not null, ref: > contract.계약ID]
  약관ID      uuid        [not null, ref: > product_terms.약관ID]

  동의일시    timestamptz [not null, default: `now()`]
  동의방식    varchar(20) [not null, note: 'APP / PAPER / KIOSK']

  생성자ID    uuid
  수정자ID    uuid
  생성일시    timestamptz [not null, default: `now()`]
  수정일시    timestamptz [not null, default: `now()`]

  indexes {
    (계약ID, 약관ID) [pk]
    계약ID
  }
}

Table contract_rate_benefit {
  계약ID        uuid         [not null, ref: > contract.계약ID]
  우대금리ID    uuid         [not null, ref: > product_rate_benefit.우대금리ID]

  적용금리      decimal(7,4) [not null, note: '계약 당시 실제 적용된 우대금리 값 스냅샷']

  생성자ID      uuid
  수정자ID      uuid
  생성일시      timestamptz  [not null, default: `now()`]
  수정일시      timestamptz  [not null, default: `now()`]

  indexes {
    (계약ID, 우대금리ID) [pk]
    계약ID
  }
}

Table account {
  계좌ID                  uuid          [pk, default: `gen_random_uuid()`]
  계좌번호                varchar(30)   [not null, unique]
  계좌비밀번호hash        varchar(50)   [not null]
  당사자ID                uuid          [not null, ref: > party.당사자ID]
  계약ID                  uuid          [ref: > contract.계약ID]
  계좌유형                varchar(20)   [not null, note: 'DEPOSIT=예금 / LOAN=대출 / OVERDRAFT=마이너스통장']
  계좌상태                varchar(20)   [not null, default: 'ACTIVE', note: 'ACTIVE / DORMANT / SUSPENDED / CLOSED / FROZEN']
  잔액                    decimal(15,2) [not null, default: 0]
  통화코드                char(3)       [not null, default: 'KRW']
  개설일                  varchar(10)   [not null, default: `CURRENT_DATE`]
  해지일                  date
  최종거래일시            timestamptz

  계좌목적                       varchar(20)   [note: 'GENERAL / SALARY / SAVINGS / UTILITY / BUSINESS / INVESTMENT']

  // 해지 권한
  본인외해지허용여부             boolean       [not null, default: false, note: '대리인·법정대리인 해지 허용 여부']

  // 표시 설정
  숨김여부                       boolean       [not null, default: false]
  표시순서                       smallint      [not null, default: 0]

  // 보안
  잠금여부                       boolean       [not null, default: false]
  비밀번호오류횟수               smallint      [not null, default: 0]
  잠금일시                       timestamptz   [note: '잠금 발생 시각']

  // 이체한도 (NULL이면 individual 기본값 적용)
  건별이체한도                   decimal(15,2)
  일일이체한도                   decimal(15,2)

  생성자ID    uuid
  수정자ID    uuid
  생성일시    timestamptz [not null, default: `now()`]
  수정일시    timestamptz [not null, default: `now()`]

  indexes {
    당사자ID
    계약ID
    계좌상태
  }
}

// 적금
Table savings_payment {
  적금납입ID      uuid          [pk, default: `gen_random_uuid()`]
  계좌ID          uuid          [not null, ref: > account.계좌ID]

  납입회차        smallint      [not null, note: '납입 회차 (1부터 시작)']
  예정납입일      varchar(10)   [not null, note: '예정 납입일']
  약정납입금액    decimal(15,2) [not null, note: '약정 납입금액']

  실제납입일      varchar(10)   [note: '실제 납입일']
  실제납입금액    decimal(15,2) [note: '실제 납입금액']
  거래ID          uuid          [ref: > transaction.거래ID, note: '실제 거래 연결 (NULL=미납)']

  납입상태        varchar(20)   [not null, default: 'SCHEDULED', note: 'SCHEDULED / PAID / PARTIAL / MISSED']

  생성자ID        uuid
  수정자ID        uuid
  생성일시        timestamptz   [not null, default: `now()`]
  수정일시        timestamptz   [not null, default: `now()`]

  indexes {
    (계좌ID, 납입회차) [unique]
    계좌ID
    납입상태
  }
}

Table internal_account {
  내부계좌ID          uuid          [pk, default: `gen_random_uuid()`]
  내부계좌번호        varchar(30)   [not null, unique]
  계약ID              uuid          [ref: > contract.계약ID]
  내부계좌유형        varchar(30)   [not null, note: 'DEPOSIT / OVERDRAFT_LOAN / SEIZED_DEPOSIT / LOAN']
  상태                varchar(20)   [not null, default: 'ACTIVE', note: 'ACTIVE / SUSPENDED / CLOSED / FROZEN']
  한도                decimal(15,2) [note: 'OVERDRAFT_LOAN 전용. NULL=해당없음']
  잔액                decimal(15,2) [not null, default: 0, note: 'OVERDRAFT_LOAN은 음수 가능 (-한도 이상)']
  통화코드            char(3)       [not null, default: 'KRW']
  개설일              varchar(10)   [not null, default: `CURRENT_DATE`]
  해지일              date

  생성자ID    uuid
  수정자ID    uuid
  생성일시    timestamptz [not null, default: `now()`]
  수정일시    timestamptz [not null, default: `now()`]

  indexes {
    계약ID
    상태
  }
}

Table transaction {
  거래ID                  uuid          [pk, default: `gen_random_uuid()`]
  계좌ID                  uuid          [not null, ref: > account.계좌ID]

  거래유형                varchar(20)   [not null, note: 'DEPOSIT / WITHDRAWAL / TRANSFER_OUT / TRANSFER_IN / INTEREST / FEE']
  거래금액                decimal(15,2) [not null]
  거래전잔액              decimal(15,2) [not null]
  거래후잔액              decimal(15,2) [not null]

  거래상태                    varchar(20)   [not null, default: 'COMPLETED', note: 'COMPLETED / PENDING / FAILED / CANCELLED']
  거래채널                    varchar(20)   [note: 'APP / ATM / TELLER / INTERNET / AUTO / SCHEDULED']

  상대방계좌번호          varchar(30)
  상대방은행코드          varchar(10)
  상대방명                varchar(100)
  상대방당사자ID          uuid          [ref: > party.당사자ID, note: '내부 고객인 경우 party 연결']
  상대방계좌ID            uuid          [ref: > account.계좌ID, note: '동행 이체 시 계좌 직접 연결']
  송금은행코드            varchar(10)   [note: '송금인 은행 코드 (상대방은행코드=수취인 은행과 구분)']
  받는사람표시            varchar(20)
  보내는사람표시          varchar(20)

  거래번호                varchar(30)   [unique, note: '고객용 거래번호 (영수증·명세서 표시, 예: 20260515-000123)']
  거래키                  varchar(50)   [unique, note: '외부 시스템 통합용 고유 거래 키']
  참조번호                varchar(50)   [note: '금융결제원 거래 참조번호']
  배치ID                  uuid          [note: '대량처리/정산 배치 그룹 ID']

  수수료금액              decimal(15,2)
  세금금액                decimal(15,2) [note: '이자소득세 등']

  이체방식                varchar(20)   [note: 'REALTIME / AGGREGATE / NIGHT / SAME_DAY']
  결제일                  varchar(10)   [note: '거래일자와 결제일이 다를 경우 (익영업일 결제 등)']

  승인자ID                uuid          [ref: > employee.직원ID]
  승인일시                timestamptz
  거절사유                varchar(200)

  리스크스코어            decimal(5,2)
  이상거래여부            boolean       [not null, default: false]
  IP주소                  inet
  기기식별자              varchar(100)

  적요                    varchar(200)
  사용자메모              text          [note: '고객 입력 메모 (적요보다 긴 메모용)']

  거래일자                varchar(10)   [not null, default: `CURRENT_DATE`]
  거래일시                timestamptz   [not null, default: `now()`]

  생성자ID                uuid
  수정자ID                uuid
  생성일시                timestamptz   [not null, default: `now()`]
  수정일시                timestamptz   [not null, default: `now()`]

  indexes {
    계좌ID
    (거래일시)
    거래유형
    거래키 [unique]
    배치ID
    이상거래여부
    결제일
  }
}

Table account_mapping {
  매핑ID          uuid        [pk, default: `gen_random_uuid()`]
  대표계좌ID      uuid        [not null, ref: > account.계좌ID]
  내부계좌ID      uuid        [not null, ref: > internal_account.내부계좌ID]
  매핑유형        varchar(30) [not null, note: 'GENERAL_DEPOSIT / OVERDRAFT_LOAN / SEIZED_DEPOSIT / LOAN']
  상태코드        varchar(20) [not null, default: 'ACTIVE', note: 'ACTIVE / PAYMENT_SUSPENDED / SEIZED / CLOSED']
  우선순위        smallint    [not null, default: 1, note: '1이 최우선']
  효력발생일시    timestamptz [note: '효력 발생 일시 (압류 명령 송달 시간 등)']

  생성자ID    uuid
  수정자ID    uuid
  생성일시    timestamptz [not null, default: `now()`]
  수정일시    timestamptz [not null, default: `now()`]

  indexes {
    (대표계좌ID, 내부계좌ID) [unique]
    대표계좌ID
    내부계좌ID
    상태코드
  }
}


// ============================================================
// 기업뱅킹 도메인
// ============================================================

Table corporate_role_policy {
  역할                varchar(30)   [pk, note: 'VIEWER / TRANSFER_REQUESTER / APPROVER / ADMIN']
  이체요청가능여부    boolean       [not null, default: false]
  승인가능여부        boolean       [not null, default: false]
  건별이체한도        decimal(15,2) [note: 'NULL=무제한']
  일일이체한도        decimal(15,2) [note: 'NULL=무제한']
  생성자ID            uuid
  수정자ID            uuid
  생성일시            timestamptz   [not null, default: `now()`]
  수정일시            timestamptz   [not null, default: `now()`]
}

Table corporate_user {
  담당직원ID            uuid         [pk, default: `gen_random_uuid()`]
  법인ID                uuid         [not null, ref: > corporate.법인ID]
  담당직원이메일                varchar(255) [not null, unique]

  담당직원명            varchar(100) [not null]
  담당직원부서          varchar(100)
  담당직원직급          varchar(100)
  담당직원역할          varchar(30)  [not null, default: 'VIEWER', ref: > corporate_role_policy.역할]
  담당직원상태          varchar(20)  [not null, default: 'ACTIVE', note: 'ACTIVE / LOCKED / DISABLED']

  로그인실패횟수        int          [not null, default: 0]
  잠금일시              timestamptz
  최종로그인일시        timestamptz

  생성자ID              uuid
  수정자ID              uuid
  생성일시              timestamptz  [not null, default: `now()`]
  수정일시              timestamptz  [not null, default: `now()`]

  indexes {
    법인ID
    담당직원이메일
  }
}

// ============================================================
// 인프라·조직 도메인
// ============================================================

Table branch {
  지점ID       uuid         [pk, default: `gen_random_uuid()`]
  지점코드     varchar(10)  [not null, unique, note: '점포코드 (금융결제원 기준)']
  지점명       varchar(100) [not null]
  지점유형     varchar(20)  [not null, note: 'HEAD_OFFICE / BRANCH / SUB_BRANCH']
  지점상태     varchar(20)  [not null, default: 'ACTIVE', note: 'ACTIVE / CLOSED / SUSPENDED']

  우편번호     varchar(5)
  주소         varchar(200)
  상세주소     varchar(100)

  전화번호     varchar(20)
  팩스번호     varchar(20)

  영업시작시간 time         [note: '예: 09:00']
  영업종료시간 time         [note: '예: 16:00']

  개점일       date
  폐점일       date

  생성자ID     uuid
  수정자ID     uuid
  생성일시     timestamptz  [not null, default: `now()`]
  수정일시     timestamptz  [not null, default: `now()`]

  indexes {
    지점상태
    지점유형
  }
}


Table employee {
  직원ID       uuid         [pk, default: `gen_random_uuid()`]
  지점ID       uuid         [not null, ref: > branch.지점ID]
  당사자ID     uuid         [ref: > party.당사자ID, note: 'NULL=은행 고객이 아닌 직원']

  사번         varchar(20)  [not null, unique]
  이름         varchar(100) [not null]
  부서         varchar(100)
  직위         varchar(50)

  이메일       varchar(200)
  전화번호     varchar(20)

  직원상태     varchar(20)  [not null, default: 'ACTIVE', note: 'ACTIVE / ON_LEAVE / RESIGNED']
  입사일       varchar(10)  [not null]
  퇴사일       date

  생성자ID     uuid
  수정자ID     uuid
  생성일시     timestamptz  [not null, default: `now()`]
  수정일시     timestamptz  [not null, default: `now()`]

  indexes {
    지점ID
    사번
  }
}


// ============================================================
// 대출 신청 프로세스 도메인
// ============================================================
/*
Table loan_application {
  신청ID              uuid          [pk, default: `gen_random_uuid()`]
  당사자ID            uuid          [not null, ref: > party.당사자ID]
  상품ID              uuid          [not null, ref: > product.상품ID]

  신청금액            decimal(15,2) [not null]
  신청기간월수        int
  대출목적            varchar(100)

  신청상태            varchar(20)   [not null, default: 'DRAFT', note: 'DRAFT / SUBMITTED / REVIEWING / APPROVED / REJECTED / EXECUTED / CANCELLED']

  승인금액            decimal(15,2)
  승인금리            decimal(7,4)
  거절사유            varchar(500)

  계약ID              uuid          [ref: > contract.계약ID, note: '실행 후 연결']

  신청채널            varchar(20)   [note: 'APP / INTERNET / BRANCH / PHONE']
  지점ID              uuid          [ref: > branch.지점ID]
  담당직원ID          uuid          [ref: > employee.직원ID]

  제출일시            timestamptz
  결정일시            timestamptz

  생성자ID            uuid
  수정자ID            uuid
  생성일시            timestamptz   [not null, default: `now()`]
  수정일시            timestamptz   [not null, default: `now()`]

  indexes {
    당사자ID
    상품ID
    신청상태
  }
}

Table loan_approval_step {
  단계ID          uuid         [pk, default: `gen_random_uuid()`]
  신청ID          uuid         [not null, ref: > loan_application.신청ID]

  단계순서        smallint     [not null, note: '1부터 시작']
  심사직원ID      uuid         [not null, ref: > employee.직원ID]

  단계상태        varchar(20)  [not null, default: 'PENDING', note: 'PENDING / APPROVED / REJECTED / SKIPPED']
  의견            text
  결정일시        timestamptz

  생성자ID        uuid
  수정자ID        uuid
  생성일시        timestamptz  [not null, default: `now()`]
  수정일시        timestamptz  [not null, default: `now()`]

  indexes {
    (신청ID, 단계순서) [unique]
    신청ID
  }
}

Table loan_document {
  서류ID          uuid         [pk, default: `gen_random_uuid()`]
  신청ID          uuid         [not null, ref: > loan_application.신청ID]

  서류유형        varchar(50)  [not null, note: 'ID_CARD / INCOME_PROOF / EMPLOYMENT_CERT / PROPERTY_CERT / TAX_RETURN / BANK_STATEMENT / OTHER']
  파일명          varchar(255)
  파일URL         text

  확인여부        boolean      [not null, default: false]
  확인직원ID      uuid         [ref: > employee.직원ID]
  확인일시        timestamptz

  생성자ID        uuid
  수정자ID        uuid
  생성일시        timestamptz  [not null, default: `now()`]
  수정일시        timestamptz  [not null, default: `now()`]

  indexes {
    신청ID
  }
}

Table loan_collateral {
  담보ID          uuid          [pk, default: `gen_random_uuid()`]
  신청ID          uuid          [not null, ref: > loan_application.신청ID]

  담보유형        varchar(30)   [not null, note: 'REAL_ESTATE / DEPOSIT / SECURITIES / VEHICLE / OTHER']

  소재지          varchar(300)  [note: '부동산 담보 전용']
  등기번호        varchar(30)   [note: '부동산 등기번호']

  감정가          decimal(15,2)
  감정기준일      date
  감정기관명      varchar(100)
  근저당설정금액  decimal(15,2)

  생성자ID        uuid
  수정자ID        uuid
  생성일시        timestamptz   [not null, default: `now()`]
  수정일시        timestamptz   [not null, default: `now()`]

  indexes {
    신청ID
  }
}
*/

Table loan_delinquency {
  연체ID          uuid          [pk, default: `gen_random_uuid()`]
  계약ID          uuid          [not null, ref: > contract.계약ID]

  연체상태        varchar(20)   [not null, note: 'OVERDUE=연체 / DEFAULT=부도 / RECOVERED=정상화']

  연체원금        decimal(15,2) [not null, default: 0]
  연체이자        decimal(15,2) [not null, default: 0]
  연체일수        int           [not null]

  연체시작일      varchar(10)   [not null]
  정상화일        varchar(10)   [note: 'NULL=현재 연체 중']

  생성자ID        uuid
  수정자ID        uuid
  생성일시        timestamptz   [not null, default: `now()`]
  수정일시        timestamptz   [not null, default: `now()`]

  indexes {
    계약ID
    연체상태
  }
}


// ============================================================
// 로그·감사 도메인
// ============================================================

Table audit_log {
  감사ID                  uuid         [pk, default: `gen_random_uuid()`]
  테이블명                varchar(100) [not null]
  레코드ID                uuid         [not null]
  작업유형                varchar(10)  [not null, note: 'INSERT / UPvarchar(10) / DELETE']
  이전값                  json
  변경값                  json
  변경자ID                uuid         [not null]
  변경일시                timestamptz  [not null, default: `now()`]

  준법감시필요여부        boolean      [not null, default: false]
  준법감시승인여부        boolean
  준법감시승인자ID        uuid
  준법감시승인일시        timestamptz

  IP주소                  varchar(45)
  세션ID                  varchar(100)

  생성자ID                uuid
  수정자ID                uuid
  생성일시                timestamptz  [not null, default: `now()`]
  수정일시                timestamptz  [not null, default: `now()`]

  indexes {
    (테이블명, 레코드ID)
    (변경일시)
  }
}
