{
  "name": "tmp-init",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "tsx --env-file=.env prisma/seed.ts",
    "kafka:gateway": "tsx --env-file=.env workers/interbank-gateway.ts",
    "kafka:simulator": "tsx --env-file=.env interbank-simulator/src/index.ts",
    "kafka:settlement": "tsx --env-file=.env workers/settlement-consumer.ts",
    "kafka:inbound": "tsx --env-file=.env workers/inbound-consumer.ts",
    "kafka:all": "concurrently -n gateway,simulator,settlement,inbound -c blue,yellow,green,cyan \"npm run kafka:gateway\" \"npm run kafka:simulator\" \"npm run kafka:settlement\" \"npm run kafka:inbound\"",
    "kafka:seed": "tsx interbank-simulator/seed.ts",
    "worker:scheduled": "tsx --env-file=.env workers/scheduled-transfer-worker.ts",
    "loan:train": "python loan_model.py",
    "loan:ml": "uvicorn loan_inference_server:app --port 8001 --reload"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^0.0.72",
    "@ai-sdk/react": "^0.0.70",
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/bcryptjs": "^2.4.6",
    "ai": "^4.3.19",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "kafkajs": "^2.2.4",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "ollama-ai-provider": "^1.2.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.1",
    "typescript": "^5"
  }
}
